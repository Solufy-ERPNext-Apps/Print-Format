 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n\ndiv{\n border-top:none!important;   \n}\n\ntable tr th,\ntable tr td{\n    border-top:none !important;\n}\n  .fit-to-page {\n    zoom: 0.80;\n    transform: scale(0.95);\n    transform-origin: top left;\n    width: 100%;\n  }\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n.check tr td{\n    border:none ;\n\n    \n}\n.check tr td:nth-child(3) {\n    border-left: 1px solid black;\n}\n.check tr td:nth-child(1),\n.check tr td:nth-child(3) {\n    font-weight: bold;\n}\n  body {\n    font-family: Arial, sans-serif;\n    font-size: 11px;\n    background: white;\n    color: #000;\n    -webkit-print-color-adjust: exact;\n  }\n  .page { width: 100%; padding: 10px; }\n  .info-table {\n      border:none;\n      \n    width: 100%;\n    border-collapse: collapse;\n    /*border: 1px solid #000;*/\n    border-top: none;\n  }\n  .info-table td {\n    /*border: 1px solid #000;*/\n    padding: 3px 6px;\n    vertical-align: top;\n    font-size: 10.5px;\n  }\n  \n  . { font-weight: bold; width: 160px; }\n  .items-table {\n    width: 100%;\n    border-collapse: collapse;\n    border: 1px solid #000;\n    border-top: none;\n  }\n  .items-table th {\n    background-color: #f0f0f0;\n    border: 1px solid #000;\n    padding: 4px;\n    text-align: center;\n    font-size: 10px;\n    vertical-align: middle;\n  }\n  .items-table td {\n    border: 1px solid #000;\n    padding: 3px 4px;\n    font-size: 10px;\n    vertical-align: top;\n  }\n  .totals-table {\n    width: 100%;\n    border-collapse: collapse;\n    border: 1px solid #000;\n    border-top: none;\n  }\n  .totals-table td {\n    border: 1px solid #000;\n    padding: 3px 8px;\n    font-size: 10.5px;\n  }\n  .footer-table {\n    width: 100%;\n    border-collapse: collapse;\n    border: 1px solid #000;\n    border-top: none;\n  }\n  .footer-table td {\n    border: 1px solid #000;\n    padding: 5px 8px;\n    font-size: 10px;\n    vertical-align: top;\n  }\n  .text-center { text-align: center; }\n  .text-right  { text-align: right; }\n  .bold        { font-weight: bold; }\n  .grand-total { font-size: 13px; font-weight: bold; background-color: #f0f0f0; }\n  .sign-box { text-align: center; padding-top: 30px; font-size: 10px; }\n  .bottom-note {\n    text-align: center; font-size: 10px;\n    border: 1px solid #000; border-top: none; padding: 4px;\n  }\n  .company-name { font-size: 14px; font-weight: bold; }\n .main-div {\n    display: table;\n    width: 100%;\n    border-collapse: collapse;\n    border: 1px solid #000;\n    border-top: none;\n  }\n  .main-div-row {\n    display: table-row;\n  }\n  .left-div {\n    display: table-cell;\n    width: 35%;\n    vertical-align: top;\n    padding: 6px;\n    border-right: 1px solid #000;\n  }\n  .right-div {\n    display: table-cell;\n    width: 65%;\n    vertical-align: top;\n    padding: 0;\n  }\n  .city td{\n      border-bottom:1px solid black;\n  }\n  </style>\n</head>\n<body>\n<div class=\"fit-to-page\">\n     <div>\n           {% if letter_head %}\n           {{ letter_head }}\n           {%else%}\n           {% endif %}\n    </div>\n    <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"text-align:center; font-size:16px; font-weight:bold; padding:6px 10px;\">\n        {{ _(\"Tax Invoices\") }}\n      </td>\n    </tr>\n  </table>\n    \n<div class=\"main-div\">\n  <div class=\"main-div-row\">\n \n    <!-- LEFT DIV: Buyer Info -->\n    <div class=\"left-div\">\n     \n            <div><b>{{ _(\"Buyer\") }}</b></div>\n            <div><b>{{ doc.customer_name }}</b></div>\n            {{ doc.address_display or \"\" }}\n            {% set ba = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None %}\n            {% if ba %}\n              <div>{{ _(\"TRN\") }} : {{ ba.gstin or \"\" }}</div>\n            {% endif %}\n            {% if doc.place_of_supply %}\n              <div>{{ _(\"Place of supply\") }} : {{ doc.place_of_supply }}</div>\n            {% endif %}\n\n    </div>\n \n        <div class=\"right-div\">\n      <table  class=\"info-table check\">\n        <tr>\n          <td>{{ _(\"Invoice No.\") }}</td>\n          <td>{{ doc.name }}</td>\n          <td>{{ _(\"Dated:\") }}</td>\n          <td>{{ doc.get_formatted(\"posting_date\") }}</td>\n        </tr>\n        <tr>\n          <td>{{ _(\"Delivery Note:\") }}</td>\n          <td>{{ doc.items[0].delivery_note if doc.items and doc.items[0].delivery_note else \"\" }}</td>\n          <td style='white-space:nowrap'>{{ _(\"Mode/Terms of Payment:\") }}</td>\n          <td>{{ doc.payment_terms_template or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>{{ _(\"Supplier's Ref:\") }}</td>\n          <td>{{ doc.po_no or \"\" }}</td>\n          <td>{{ _(\"Other References:\") }}</td>\n          <td>{{ doc.remarks or \"\" }}</td>\n        </tr>\n        <tr>\n          <td>{{ _(\"Buyer's Order No.:\") }}</td>\n          <td>{{ doc.po_no or \"\" }}</td>\n          <td>{{ _(\"Dated:\") }}</td>\n          <td>{{ doc.get_formatted(\"po_date\") }}</td>\n        </tr>\n        <tr>\n          <td style='white-space:nowrap'>{{ _(\"Dispatched Through:\") }}</td>\n          <td>{{ doc.transporter_name or \"\" }}</td>\n          <td>{{ _(\"Destination:\") }}</td>\n          <td>{{ doc.shipping_address_name or \"\" }}</td>\n        </tr>\n        <tr class='city'>\n          <td style=' border-bottom:1px solid black;white-space:nowrap'>{{ _(\"City/Port of Loading:\") }}</td>\n          <td style=' border-bottom:1px solid black;white-space:nowrap'>{{ doc.shipping_address_name or \"\" }}</td>\n          <td style=' border-bottom:1px solid black;'>{{ _(\"Place of Supply:\") }}</td>\n          <td style=' border-bottom:1px solid black;'>{{ doc.place_of_supply or \"\" }}</td>\n        </tr>\n        <tr>\n            <td style='white-space:nowrap'>\n                <b>Terms Of Delievery :</b><br>\n                {{doc.incoterm or ''}}\n            </td>\n        </tr>\n      </table>\n    </div>\n \n  </div>\n</div>\n \n  <!-- INVOICE META -->\n \n  <!-- ITEMS TABLE -->\n  <table class=\"items-table\">\n    <thead>\n      <tr>\n        <th style=\"width:28px;\">{{ _(\"Sr No.\") }}</th>\n        <th>{{ _(\"Description of Goods\") }}</th>\n        <th style=\"width:65px;\">{{ _(\"Quantity\") }}</th>\n        <th style=\"width:50px;\">{{ _(\"Rate\") }}</th>\n        <th style=\"width:35px;\">{{ _(\"Per\") }}</th>\n        <th style=\"width:40px;\">{{ _(\"VAT\") }} %</th>\n        <th style=\"width:70px;\">{{ _(\"Taxable Value\") }} {{doc.currency}}</th>\n        <th style=\"width:60px;\">{{ _(\"VAT Amount\") }} {{doc.currency}}</th>\n        <th style=\"width:75px;\">{{ _(\"Total Incl. VAT\") }} {{doc.currency}}</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set vat_rate = namespace(value=5) %}\n      {% for tax in doc.taxes %}\n        {% if tax.charge_type == \"On Net Total\" %}\n          {% set vat_rate.value = tax.rate %}\n        {% endif %}\n      {% endfor %}\n\n      {% for item in doc.items %}\n      <tr>\n        <td class=\"text-center\">{{ loop.index }}</td>\n        <td>\n          <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n        <td class=\"text-center\">{{ item.qty | int }} </td>\n        <td class=\"\" style='white-space:nowrap' >{{item.get_formatted(\"rate\")}}</td>\n        <td class=\"text-center\">{{ item.uom }}</td>\n        <td class=\"text-center\">{{ vat_rate.value }}%</td>\n        <td class=\"text-right\">{{ item.get_formatted(\"amount\") }}</td>\n        <td class=\"text-right\">{{ frappe.utils.fmt_money(item.amount * vat_rate.value / 100, currency=doc.currency) }}</td>\n        <td class=\"text-right bold\">{{ frappe.utils.fmt_money(item.amount * (1 + vat_rate.value / 100), currency=doc.currency) }}</td>\n      </tr>\n      {% endfor %}\n\n    </tbody>\n    <tfoot>\n      <tr>\n        <td colspan=\"2\" class=\"text-right bold\">{{ _(\"Total\") }}</td>\n        <td class=\"text-center bold\">\n          {% set total_qty = namespace(value=0) %}\n          {% for item in doc.items %}{% set total_qty.value = total_qty.value + item.qty %}{% endfor %}\n          {{ total_qty.value | int }}\n        </td>\n        <td colspan=\"3\"></td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"total\") }}</td>\n        <td class=\"text-right bold\">\n          {% set vat = namespace(value=0) %}\n          {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n          {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n        </td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"grand_total\") }}</td>\n      </tr>\n    </tfoot>\n  </table>\n\n  <!-- TOTALS BREAKDOWN -->\n  <table class=\"totals-table\">\n    <tr>\n      <td style=\"width:55%; vertical-align:top;\">\n        <b>{{ _(\"Amount Chargeable (in words)\") }}</b><br>\n        {{ doc.in_words or \"\" }}\n        <br>\n       <b> {{ _(\"VAT Amount Chargeable (in words)\") }}</b>\n        <br>\n        {% set vat = namespace(value=0) %}\n              {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n              \n        {{ frappe.utils.money_in_words(vat.value,doc.currency) }}\n      </td>\n      <td style=\"width:45%;\">\n        <table style=\"width:100%; border-collapse:collapse;\">\n          <tr>\n            <td>{{ _(\"Taxable Value\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"total\") }}</td>\n          </tr> \n          <tr>\n            <td>{{ _(\"Value Added Tax\") }} {{ vat_rate.value }}%</td>\n            <td class=\"text-right\">\n              {% set vat = namespace(value=0) %}\n              {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n              {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n            </td>\n          </tr>\n          {% if doc.discount_amount %}\n          <tr>\n            <td>{{ _(\"Discount\") }}</td>\n            <td class=\"text-right\">(-{{ doc.get_formatted(\"discount_amount\") }})</td>\n          </tr>\n          {% endif %}\n          {% if doc.rounding_adjustment %}\n          <tr>\n            <td>{{ _(\"Rounded Off\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"rounding_adjustment\") }}</td>\n          </tr>\n          {% endif %}\n          <tr class=\"grand-total\">\n            <td><b>{{ _(\"Invoice Total\") }}</b></td>\n            <td class=\"text-right bold\">\n              <b>\n                {% if doc.disable_rounded_total %}\n                  {{ doc.get_formatted(\"grand_total\") }}\n                {% else %}\n                  {{ doc.get_formatted(\"rounded_total\") or doc.get_formatted(\"grand_total\") }}\n                {% endif %}\n              </b>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n <div style=\"width:100%; display:table; border:1px solid #000; border-collapse:collapse;\">\n    <div style=\"display:table-row;\">\n\n      <div style=\"display:table-cell; width:55%; padding:5px; vertical-align:top; border-right:1px solid #000;\">\n        <strong>Terms &amp; Conditions:</strong><br>\n        <div style=\"white-space:pre-wrap;\">{{ doc.terms or \"\" }}</div>\n      </div>\n\n     \n      <div style=\"display:table-cell; width:25%; padding:5px; text-align:center; vertical-align:top;\">\n        <b>For, {{ doc.company }}</b>\n        <br><br><br><br>\n        Authorised Signatory\n      </div>\n\n    </div>\n  </div>\n\n  <!--<!-- BOTTOM NOTE -->\n  <div class=\"bottom-note\">\n    {{ _(\"This is a Computer Generated Invoice\") }}\n  </div>\n\n\n</div>\n</body>\n</html>",
