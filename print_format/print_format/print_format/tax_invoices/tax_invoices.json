{
 "absolute_value": 0,
 "align_labels_right": 0,
 "country": "India",
 "creation": "2026-03-17 12:02:54.613791",
 "css": "",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Sales Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<html>\n<head>\n<style>\n  td {\n    overflow: visible !important;\n  }\n  .mt tbody tr {\n    height: 32px;\n    min-height: 32px;\n  }\n  .filler-row td {\n    height: 32px;\n  }\n  .filler-row td:empty::after {\n    content: \"\\00a0\";\n  }\n  .mt td:nth-child(2) {\n    word-break: break-word;\n  }\n  *::-webkit-scrollbar {\n    display: none;\n  }\n  .gt {\n    margin: 0px !important;\n    padding: 0px !important;\n  }\n  .mt {\n    border-collapse: collapse !important;\n    border-spacing: 0 !important;\n  }\n  .mt thead {\n    display: table-header-group;\n  }\n  .mt tfoot {\n    display: table-footer-group;\n  }\n  .mt tr td {\n    padding: 5px 6px !important;\n    border: none !important;\n    border-left: 1px solid black !important;\n  }\n  .mt thead tr td {\n    border-bottom: 1px solid #000 !important;\n  }\n  .mt tbody tr:first-child td {\n    padding-top: 2px !important;\n  }\n  .mt tr {\n    page-break-inside: avoid !important;\n    break-inside: avoid !important;\n  }\n  .page-break {\n    page-break-after: always;\n    break-after: page;\n  }\n  .fit-to-page {\n    width: 100%;\n    margin: 0;\n    padding: 0;\n  }\n  table {\n    border-collapse: collapse;\n  }\n  .main {\n    border-collapse: collapse;\n  }\n  .main td {\n    border: none !important;\n  }\n  .main tr td:nth-child(1) {\n    border-bottom: 1px solid black !important;\n  }\n  .main tr td:nth-child(2) {\n    border-bottom: 1px solid black !important;\n    border-left: 1px solid black !important;\n  }\n  table thead tr td {\n    font-weight: bold;\n  }\n  @page {\n    size: A4;\n    margin: 8mm 5mm 8mm 5mm;\n  }\n  html, body {\n    margin: 0;\n    padding: 0;\n    font-family: Arial, sans-serif;\n    font-size: 11px;\n    line-height: 1.15;\n    -webkit-print-color-adjust: exact;\n    background: white;\n  }\n  .filler-row td {\n    height: 20px !important;\n    border-bottom: none !important;\n  }\n  .mt {\n    border-bottom: 1px solid black !important;\n  }\n  .table1 tr td:nth-child(4) {\n    border-left: 1px solid black !important;\n  }\n  table {\n    border: 1px solid black;\n  }\n</style>\n</head>\n<body>\n<div class='fit-to-page page-break'>\n\n{# \u2500\u2500 LETTER HEAD \u2500\u2500 #}\n<div class='tab-cont'>\n  <div>\n    {% if letter_head %}{{ letter_head }}{% endif %}\n  </div>\n</div>\n\n<!-- TITLE -->\n<table style=\"width:100%; font-size:13px; line-height:0.4; border:1px solid #000; border-top:none;\">\n  <tr>\n    <td style=\"font-size:15px; background-color:#D3D3D3; padding:5px;\">\n      <b><center>Tax Invoice</center></b>\n    </td>\n  </tr>\n</table>\n\n<!-- INVOICE META -->\n<table style=\"width:100%; border:1px solid #000; border-top:none; border-collapse:collapse; table-layout:fixed; line-height:0.3\" class='table1'>\n  <colgroup>\n    <col style=\"width:18%\">\n    <col style=\"width:2%\">\n    <col style=\"width:30%\">\n    <col style=\"width:22%\">\n    <col style=\"width:2%\">\n    <col style=\"width:26%\">\n  </colgroup>\n  <tr>\n    <td style=\"border:none;\"><strong>Invoice No.</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\"><b>{{ doc.name or \"\" }}</b></td>\n    <td style=\"border:none;\"><strong>Delivery Note</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.delivery_note or \"\" }}</td>\n  </tr>\n  <tr>\n    <td style=\"border:none;\"><strong>Invoice Date</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ frappe.format_date(doc.posting_date, \"dd-MM-yyyy\") if doc.posting_date else \"\" }}</td>\n    <td style=\"border:none;\"><strong>Payment Terms</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.payment_terms_template or \"\" }}</td>\n  </tr>\n  <tr>\n    <td style=\"border:none;\"><strong>Order No.</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.po_no or \"\" }}</td>\n    <td style=\"border:none;\"><strong>Transport</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.transporter_name or \"\" }}</td>\n  </tr>\n  <tr>\n    <td style=\"border:none;\"><strong>Order Date</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ frappe.format_date(doc.po_date, \"dd-MM-yyyy\") if doc.po_date else \"\" }}</td>\n    <td style=\"border:none;\"><strong>Dispatch No.</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.lr_no or \"\" }}</td>\n  </tr>\n  <tr>\n    <td style=\"border:none;\"><strong>GSTIN</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.company_gstin or \"\" }}</td>\n    <td style=\"border:none;\"><strong>Destination</strong></td>\n    <td style=\"border:none;\">:</td>\n    <td style=\"border:none;\">{{ doc.shipping_address_name or \"\" }}</td>\n  </tr>\n</table>\n\n<!-- COMPANY / CONSIGNEE / BUYER -->\n<table style=\"width:100%; border:1px solid #000; border-top:none; border-collapse:collapse;\">\n  <tr style=\"background-color:#f0f0f0;\">\n    <td style=\"width:33%; text-align:center; border-right:1px solid #000;\"><strong>Supplier (Company)</strong></td>\n    <td style=\"width:33%; text-align:center; border-right:1px solid #000;\"><strong>Consignee (Ship to)</strong></td>\n    <td style=\"width:34%; text-align:center;\"><strong>Buyer (Bill to)</strong></td>\n  </tr>\n  <tr>\n    <td style=\"padding:8px; vertical-align:top; border-right:1px solid #000;\">\n      <b>{{ doc.company or \"\" }}</b><br>\n      {% if doc.company_address %}\n        {% set ca = frappe.get_doc(\"Address\", doc.company_address) %}\n        {{ ca.address_line1 or \"\" }}, {{ ca.city or \"\" }}<br>\n      {% endif %}\n      GSTIN: {{ doc.company_gstin or \"\" }}<br>\n      State: {{ doc.company_address_display or \"\" }}\n    </td>\n    <td style=\"padding:8px; vertical-align:top; border-right:1px solid #000;\">\n      <b>{{ doc.shipping_address_name or doc.customer_name }}</b><br>\n      {{ doc.shipping_address or doc.address_display or \"\" }}\n    </td>\n    <td style=\"padding:8px; vertical-align:top;\">\n      <b>{{ doc.customer_name }}</b><br>\n      {{ doc.address_display or \"\" }}\n    </td>\n  </tr>\n</table\n\n{% set first = doc.items[0] %}\n{% set is_igst = first.igst_rate and first.igst_rate > 0 %}\n\n<table width='100%' class=\"mt\" style=\"border-top:none;\">\n  <thead>\n    <tr>\n      <td style=\"background-color:#D3D3D3; text-align:center; width:4%;\">Sr.</td>\n      <td style=\"background-color:#D3D3D3; text-align:center; width:28%;\">Description Of Goods</td>\n      <td style=\"background-color:#D3D3D3; text-align:center; width:8%;\">HSN</td>\n      <td style=\"background-color:#D3D3D3; text-align:center; width:6%;\">Qty</td>\n      <td style=\"background-color:#D3D3D3; text-align:center; width:5%;\">UOM</td>\n      <td style=\"background-color:#D3D3D3; text-align:right; width:9%;\">Rate</td>\n      <td style=\"background-color:#D3D3D3; text-align:right; width:6%;\">Disc%</td>\n      <td style=\"background-color:#D3D3D3; text-align:right; width:9%;\">Taxable Amt</td>\n      {% if is_igst %}\n        <td style=\"background-color:#D3D3D3; text-align:center; width:10%;\">IGST</td>\n      {% else %}\n        <td style=\"background-color:#D3D3D3; text-align:center; width:10%;\">SGST</td>\n        <td style=\"background-color:#D3D3D3; text-align:center; width:10%;\">CGST</td>\n      {% endif %}\n      <td style=\"background-color:#D3D3D3; text-align:right; border-right:1px solid black; width:10%;\">Amount</td>\n    </tr>\n  </thead>\n\n  <tbody>\n    {% for item in doc.items %}\n    <tr>\n      <td style=\"text-align:center;\">{{ loop.index }}</td>\n      <td>\n        <b>{{ item.item_name }}</b>\n        {% if item.description and item.description != item.item_name %}\n          <br><small>{{ item.description }}</small>\n        {% endif %}\n      </td>\n      <td style=\"text-align:center;\">{{ item.gst_hsn_code or \"\" }}</td>\n      <td style=\"text-align:center;\">{{ item.qty or \"0\" }}</td>\n      <td style=\"text-align:center;\">{{ item.uom }}</td>\n      <td style=\"text-align:right; white-space:nowrap;\">{{ item.get_formatted(\"rate\") }}</td>\n      <td style=\"text-align:right;\">{{ item.discount_percentage or 0 }}%</td>\n      <td style=\"text-align:right; white-space:nowrap;\">{{ item.get_formatted(\"amount\") }}</td>\n\n      {% if is_igst %}\n        <!-- IGST -->\n        <td style=\"text-align:center; white-space:nowrap;\">\n          {{ item.igst_rate or 0 }}%&nbsp;\n          {{ item.get_formatted(\"igst_amount\") }}\n        </td>\n        <td style=\"text-align:right; white-space:nowrap; border-right:1px solid black;\">\n          {{ frappe.format_value(\n            (item.amount|default(0)|float) + (item.igst_amount|default(0)|float),\n            \"Currency\") }}\n        </td>\n      {% else %}\n        <!-- SGST + CGST -->\n        <td style=\"text-align:center; white-space:nowrap;\">\n          {{ item.sgst_rate or 0 }}%&nbsp;\n          {{ item.get_formatted(\"sgst_amount\") }}\n        </td>\n        <td style=\"text-align:center; white-space:nowrap;\">\n          {{ item.cgst_rate or 0 }}%&nbsp;\n          {{ item.get_formatted(\"cgst_amount\") }}\n        </td>\n        <td style=\"text-align:right; white-space:nowrap; border-right:1px solid black;\">\n          {{ frappe.format_value(\n            (item.amount|default(0)|float) +\n            (item.sgst_amount|default(0)|float) +\n            (item.cgst_amount|default(0)|float),\n            \"Currency\") }}\n        </td>\n      {% endif %}\n    </tr>\n    {% endfor %}\n\n    <!-- FILLER ROWS -->\n    {% set total_items = doc.items|length %}\n    {% if total_items < 5 %}\n      {% for i in range(5 - total_items) %}\n      <tr class=\"filler-row\">\n        <td>&nbsp;</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>\n        {% if is_igst %}\n          <td></td>\n        {% else %}\n          <td></td><td></td>\n        {% endif %}\n        <td style=\"border-right:1px solid black;\"></td>\n      </tr>\n      {% endfor %}\n    {% endif %}\n\n    <!-- TOTAL ROW -->\n    <tr style=\"border-top:1px solid black; font-weight:bold;\">\n      <td style=\"border-top:1px solid black;\"></td>\n      <td style=\"text-align:right; border-top:1px solid black;\">Total</td>\n      <td style=\"border-top:1px solid black;\"></td>\n      <td style=\"text-align:center; border-top:1px solid black;\">\n        {% set total_qty = namespace(value=0) %}\n        {% for item in doc.items %}{% set total_qty.value = total_qty.value + item.qty %}{% endfor %}\n        {{ total_qty.value | int }}\n      </td>\n      <td style=\"border-top:1px solid black;\"></td>\n      <td style=\"border-top:1px solid black;\"></td>\n      <td style=\"border-top:1px solid black;\"></td>\n      <td style=\"text-align:right; border-top:1px solid black; white-space:nowrap;\">\n        {{ doc.get_formatted(\"total\") }}\n      </td>\n\n      {% if is_igst %}\n        <td style=\"text-align:right; border-top:1px solid black; white-space:nowrap;\">\n          {% set ig = namespace(value=0) %}\n          {% for item in doc.items %}{% set ig.value = ig.value + (item.igst_amount or 0) %}{% endfor %}\n          {{ frappe.utils.fmt_money(ig.value, currency=doc.currency) }}\n        </td>\n      {% else %}\n        <td style=\"text-align:right; border-top:1px solid black; white-space:nowrap;\">\n          {% set sg = namespace(value=0) %}\n          {% for item in doc.items %}{% set sg.value = sg.value + (item.sgst_amount or 0) %}{% endfor %}\n          {{ frappe.utils.fmt_money(sg.value, currency=doc.currency) }}\n        </td>\n        <td style=\"text-align:right; border-top:1px solid black; white-space:nowrap;\">\n          {% set cg = namespace(value=0) %}\n          {% for item in doc.items %}{% set cg.value = cg.value + (item.cgst_amount or 0) %}{% endfor %}\n          {{ frappe.utils.fmt_money(cg.value, currency=doc.currency) }}\n        </td>\n      {% endif %}\n\n      <td style=\"text-align:right; border-top:1px solid black; border-right:1px solid black; white-space:nowrap;\">\n        {{ doc.get_formatted(\"grand_total\") }}\n      </td>\n    </tr>\n  </tbody>\n</table>\n\n<!-- SUMMARY SECTION -->\n<div style=\"width:100%; border:1px solid #000; border-top:none; font-size:10px; display:table; border-collapse:collapse;\">\n  <div style=\"display:table-cell; width:50%; border-right:1px solid #000; vertical-align:top;\">\n    <div style=\"border-bottom:1px solid #000; padding:5px;\">\n      Amount Chargeable (in words) :<br>\n      <b>{{ doc.in_words }}</b>\n    </div>\n    <div style=\"padding:6px;\">\n      <div style=\"display:table; width:100%;\">\n        <div style=\"display:table-cell; width:25%; vertical-align:top;\"><b>Bank Details:</b></div>\n        <div style=\"display:table-cell; vertical-align:top;\">\n          {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1, \"company\":doc.company}, \"name\") %}\n          {% if bank %}\n            {% set bank_add = frappe.get_doc(\"Bank Account\", bank) %}\n            {{ bank_add.bank }}<br>\n            A/C No: {{ bank_add.bank_account_no or \"\" }}<br>\n            IFSC: {{ bank_add.custom_ifsc or \"\" }}<br>\n            SWIFT: {{ frappe.db.get_value(\"Bank\", bank_add.bank, \"swift_number\") or \"\" }}\n          {% endif %}\n        </div>\n      </div>\n    </div>\n    {% if doc.gst_breakup_table %}\n    <div style=\"border-top:1px solid #000;\">{{ doc.gst_breakup_table }}</div>\n    {% endif %}\n  </div>\n  <div style=\"display:table-cell; width:50%; vertical-align:top;\">\n    <div style=\"display:table; width:100%; border-collapse:collapse;\" class=\"main\">\n      <div style=\"display:table-row;\">\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\"><b>Taxable Amount :</b></div>\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000; white-space:nowrap;\"><b>{{ doc.get_formatted(\"net_total\") }}</b></div>\n      </div>\n      {% for row in doc.taxes %}\n      <div style=\"display:table-row;\">\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\"><b>{{ row.description }} @ {{ row.rate }}% :</b></div>\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000; white-space:nowrap;\"><b>{{ row.get_formatted(\"tax_amount\") }}</b></div>\n      </div>\n      {% endfor %}\n      <div style=\"display:table-row;\">\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\"><b>Round off :</b></div>\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000; white-space:nowrap;\"><b>{{ doc.get_formatted(\"rounding_adjustment\") or \"0.00\" }}</b></div>\n      </div>\n      <div style=\"display:table-row;\">\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\"><b>Total Amount After Tax :</b></div>\n        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000; white-space:nowrap;\">\n          <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- TAX AMOUNT IN WORDS -->\n<table style=\"width:100%; border:1px solid #000; border-top:none;\">\n  <tr>\n    <td width=\"50%\" style=\"border-bottom:none; padding:5px;\">\n      Tax Amount (in words) :<br>\n      <b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\n    </td>\n    <td width=\"50%\" style=\"text-align:center; padding:10px; border-left:1px solid #000;\">\n      <b>Certified that the particulars given above are true</b>\n    </td>\n  </tr>\n</table>\n\n<!-- TERMS & SIGNATURE -->\n<table style=\"width:100%; table-layout:fixed; border:1px solid #000; border-top:none;\">\n  <tr>\n    <td style=\"width:70%; vertical-align:top; word-wrap:break-word; overflow-wrap:break-word; padding:5px;\">\n      <strong>Terms &amp; Conditions :</strong><br>\n      {{ doc.terms or \"\" }}\n    </td>\n    <td style=\"width:30%; text-align:center; vertical-align:top; padding:5px; border-left:1px solid #000;\">\n      <b>For, <strong>{{ doc.company }}</strong></b>\n      <br><br><br><br><br><br><br><br>\n      Authorised Signatory\n    </td>\n  </tr>\n</table>\n\n</div>\n</body>\n</html>",
