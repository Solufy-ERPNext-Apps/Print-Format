 "country": "India",
 "creation": "2026-03-06 15:25:29.849802",
 "css": "",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 1,
 "doc_type": "Sales Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n\n        html, body {\n            margin: 0;\n            padding: 0;\n            font-family: Arial, sans-serif;\n            font-size: 7.5px;\n            line-height: 1.15;\n            -webkit-print-color-adjust: exact;\n            background: white;\n        }\n        .fit-to-page {\n            zoom: 0.80;\n            transform: scale(0.95);\n            transform-origin: top left;\n            width: 100%;\n        }\n\n.print-format\n\n {\n    font-size: 9pt;\n    font-family: Inter, \"Helvetica Neue\", Helvetica, Arial, \"Open Sans\", sans-serif;\n    -webkit-print-color-adjust: exact;\n}\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { font-family: Arial, sans-serif; font-size: 12px; }\n  .invoice-box { width: 100%; border: 1px solid #000; }\n  table.main { width: 100%; border-collapse: collapse; }\n  table.main td, table.main th { border: 1px solid #000; padding: 4px 6px; vertical-align: top; font-size: 12px; }\n  table.inner { width: 100%; border-collapse: collapse; }\n  table.inner td { border: none; padding: 2px 0; font-size: 12px; vertical-align: top; }\n  \n  .text-right { text-align: right; }\n  .text-center { text-align: center; }\n  .bold { font-weight: bold; }\n.data{ border:none}\n.title-box { border:1px solid black;text-align: center; margin-bottom: 10px; }\n\n</style>\n</head>\n<body>\n    \n   <table border=1>\n       <tr>\n        <td>\n            <center><h2><b>Tax Invoice</b></h2></center>\n        </td>\n    </tr>\n   </table>\n\n\n<table style=\"width:100%; border:1px solid black; border-collapse:collapse;\">\n    \n<tr>\n    \n<td style=\"width:45%; vertical-align:top; border-right:1px solid black;\">\n<div>\n<table class=\"inner\" style=\"width:100%;\" border=\"1\">\n<tr>\n<td style=\"padding:6px; line-height:1.2;\">\n<strong style=\"font-size:13px;\">{{ doc.company }}</strong><br>\n{% if doc.company_address %}\n{% set ca = frappe.get_doc(\"Address\", doc.company_address) %}\n{{ ca.address_line1 or \"\" }}<br>\n{{ ca.city or \"\" }}<br>\n{% endif %}\nGSTIN/UIN: {{ doc.company_gstin or \"\" }}<br>\nState Name : {{ doc.company_address_display or \"\" }}\n</td>\n</tr>\n</table>\n<table class=\"inner\" style=\"width:100%;\" border=\"1\">\n<tr>\n<td style=\"padding:6px; line-height:1.2;\">\n<strong>Consignee (Ship to)</strong><br>\n{% if doc.shipping_address_name %}\n<strong>{{ doc.shipping_address_name }}</strong><br>\n{{ doc.shipping_address or \"\" }}<br>\n{% set ship_addr = frappe.get_doc(\"Address\", doc.shipping_address_name) if doc.shipping_address_name else None %}\n{% if ship_addr %}\nGSTIN/UIN : {{ ship_addr.gstin or \"\" }}<br>\nState Name : {{ ship_addr.state or \"\" }}, Code : {{ ship_addr.gst_state_number or \"\" }}\n{% endif %}\n{% else %}\n<strong>{{ doc.customer_name }}</strong><br>\n{{ doc.address_display or \"\" }}\n{% endif %}\n</td>\n</tr>\n</table>\n</div>\n</td>\n<!-- RIGHT SIDE -->\n<td style=\"width:55%; vertical-align:top;\">\n<table class=\"invoice-header-table\" border=\"1\" style=\"width:100%;\">\n<tr>\n<td style=\"width:50%\">\n<span >Invoice No.</span><br>\n<span class=\"value\">{{ doc.name }}</span>\n</td>\n<td style=\"width:50%\">\n<span >Dated</span><br>\n<span class=\"value\">{{ doc.posting_date }}</span>\n</td>\n</tr>\n<tr>\n<td>\n<span >Delivery Note</span><br>\n<span class=\"value\">{{ doc.delivery_note or \"\" }}</span>\n</td>\n<td>\n<span >Mode/Terms of Payment</span><br>\n<span class=\"value\">{{ doc.payment_terms_template or \"\" }}</span>\n</td>\n</tr>\n<tr>\n<td>\n<span >Reference No. &amp; Date.</span><br>\n<span class=\"value\">{{ doc.po_no or \"\" }}</span>\n</td>\n<td>\n<span >Other References</span><br>\n<span class=\"value\">{{ doc.remarks or \"\" }}</span>\n</td>\n</tr>\n<tr>\n<td>\n<span >Buyer's Order No.</span><br>\n<span class=\"value\">{{ doc.po_no or \"\" }}</span>\n</td>\n<td>\n<span >Dated</span><br>\n<span class=\"value\">{{ doc.po_date or \"\" }}</span>\n</td>\n</tr>\n<tr>\n<td>\n<span >Dispatch Doc No.</span><br>\n<span\nclass=\"value\">{{ doc.lr_no or \"\" }}</span>\n</td>\n<td>\n<span >Delivery Note Date</span><br>\n<span class=\"value\">{{ doc.lr_date or \"\" }}</span>\n</td>\n</tr>\n<tr>\n<td>\n<span >Dispatched through</span><br>\n<span class=\"value\">{{ doc.transporter_name or \"\" }}</span>\n</td>\n<td>\n<span >Destination</span><br>\n<span class=\"value\">{{ doc.shipping_address_name or \"\" }}</span>\n</td>\n</tr>\n<tr>\n<td colspan=\"2\">\n<span >Terms of Delivery</span><br>\n<span class=\"value\">{{ doc.terms or \"\" }}</span>\n</td>\n</tr>\n<tr>\n</table>\n</td>\n</tr>\n\n</table>\n<table border=1>\n    <tr>\n<td style=\"padding:6px; line-height:1.2;\" colspan=2>\nBuyer (Bill to)<br>\n<strong>{{ doc.customer_name }}</strong><br>\n{{ doc.address_display or \"\" }}\n{% set ba = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None %}\n{% if ba %}\n<br>\nGSTIN/UIN : {{ ba.gstin or \"\" }}<br>\nState Name : {{ ba.state or \"\" }}, Code : {{ ba.gst_state_number or \"\" }}\n{% endif %}\n</td>\n</tr>\n\n        \n    </tr>\n</table>\n<table border=1>\n    <tr>\n    <th class=\"text-center\" style=\"width:28px;\">Sl<br>No.</th>\n    <th>Description of Goods</th>\n    <th class=\"text-center\" style=\"width:68px;\">HSN/SAC</th>\n    <th class=\"text-center\" style=\"width:75px;\">Quantity</th>\n    <th class=\"text-right\" style=\"width:68px;\">Rate</th>\n    <th class=\"text-center\" style=\"width:38px;\">per</th>\n    <th class=\"text-center\" style=\"width:52px;\">Disc. %</th>\n    <th class=\"text-right\" style=\"width:82px;\">Amount</th>\n  </tr>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- ITEM ROWS                                          -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  {% for item in doc.items %}\n  <tr>\n    <td class=\"text-center\">{{ loop.index }}</td>\n    <td>\n      <table class=\"inner\">\n        <tr><td><strong>{{ item.item_name }}</strong></td></tr>\n        {% if item.description and item.description != item.item_name %}\n          <tr><td><small>{{ item.description }}</small></td></tr>\n        {% endif %}\n      </table>\n    </td>\n    <td class=\"text-center\">{{ item.gst_hsn_code or \"\" }}</td>\n    <td class=\"text-center\"><strong>{{ item.qty | int }} {{ item.uom }}</strong></td>\n    <td class=\"text-right\">{{ \"%.2f\" | format(item.rate) }}</td>\n    <td class=\"text-center\">{{ item.uom }}</td>\n    <td class=\"text-center\">{{ item.discount_percentage or \"\" }}</td>\n    <td class=\"text-right\"><strong>{{ \"%.2f\" | format(item.amount) }}</strong></td>\n  </tr>\n  {% endfor %}\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- CGST / SGST / IGST ROWS                           -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  {% for tax in doc.taxes %}\n    {% if \"CGST\" in (tax.description or \"\") or \"CGST\" in tax.account_head %}\n    <tr>\n      <td colspan=\"7\" style=\"text-align:right; border-left:none; border-top:none; border-bottom:none; padding-right:8px;\">\n        <em><strong>CGST</strong></em>\n      </td>\n      <td class=\"text-right\">{{ \"%.2f\" | format(tax.tax_amount) }}</td>\n    </tr>\n    {% endif %}\n    {% if \"SGST\" in (tax.description or \"\") or \"SGST\" in tax.account_head %}\n    <tr>\n      <td colspan=\"7\" style=\"text-align:right; border-left:none; border-top:none; border-bottom:none; padding-right:8px;\">\n        <em><strong>SGST</strong></em>\n      </td>\n      <td class=\"text-right\">{{ \"%.2f\" | format(tax.tax_amount) }}</td>\n    </tr>\n    {% endif %}\n    {% if \"IGST\" in (tax.description or \"\") or \"IGST\" in tax.account_head %}\n    <tr>\n      <td colspan=\"7\" style=\"text-align:right; border-left:none; border-top:none; border-bottom:none; padding-right:8px;\">\n        <em><strong>IGST</strong></em>\n      </td>\n      <td class=\"text-right\">{{ \"%.2f\" | format(tax.tax_amount) }}</td>\n    </tr>\n    {% endif %}\n  {% endfor %}\n\n  <!-- BLANK FILLER -->\n  <tr style=\"height:40px;\">\n    <td colspan=\"8\" style=\"border-top:none;\">&nbsp;</td>\n  </tr>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- TOTAL ROW                                          -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <tr>\n    <td colspan=\"3\" class=\"text-right bold\">Total</td>\n    <td class=\"text-center bold\">\n      {% set total_qty = namespace(value=0) %}\n      {% for item in doc.items %}{% set total_qty.value = total_qty.value + item.qty %}{% endfor %}\n      {{ total_qty.value | int }} {{ doc.items[0].uom if doc.items }}\n    </td>\n    <td colspan=\"3\">&nbsp;</td>\n    <td class=\"text-right bold\">&#x20B9; {{ \"%.2f\" | format(doc.grand_total) }}</td>\n  </tr>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- AMOUNT IN WORDS                                    -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <tr>\n    <td colspan=\"7\">\n      <table class=\"inner\">\n        <tr><td>Amount Chargeable (in words)</td></tr>\n        <tr><td><strong>{{ doc.in_words }}</strong></td></tr>\n      </table>\n    </td>\n    <td style=\"text-align:right; font-style:italic; font-size:11px; vertical-align:bottom;\">E. &amp; O.E</td>\n  </tr>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- GST BREAKUP TABLE                                  -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <tr>\n    <td colspan=\"8\" style=\"padding:0;\">\n      {{ doc.gst_breakup_table or \"\" }}\n    </td>\n  </tr>\n\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <!-- DECLARATION + SIGNATORY                            -->\n  <!-- \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 -->\n  <tr>\n    <td colspan=\"5\" style=\"vertical-align:top;\">\n      <table class=\"inner\">\n        <tr><td><strong>Declaration</strong></td></tr>\n        <tr><td>We declare that this invoice shows the actual price of the goods described and that all particulars are true and correct.</td></tr>\n      </table>\n    </td>\n    <td colspan=\"3\" style=\"vertical-align:bottom;\">\n      <table class=\"inner\" style=\"width:100%;\">\n        <tr><td style=\"text-align:right;\"><strong>for {{ doc.company }}</strong></td></tr>\n        <tr><td style=\"height:48px;\">&nbsp;</td></tr>\n        <tr><td style=\"text-align:right;\">Authorised Signatory</td></tr>\n      </table>\n    </td>\n  </tr>\n\n  <tr>\n    <td colspan=\"8\" class=\"text-center\" style=\"font-size:11px;\">\n      This is a Computer Generated Invoice\n    </td>\n  </tr>\n</table>\n</div>\n</body>\n</html>\n",
