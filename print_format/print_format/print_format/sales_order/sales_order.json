 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  * { font-size: 11px; font-family: Arial, sans-serif; margin: 0; padding: 0; box-sizing: border-box; }\n\n  /* \u2500\u2500 OUTER WRAPPER \u2500\u2500 */\n  .so-wrap { width: 100%; border: 1px solid #000; border-collapse: collapse; }\n\n  /* \u2500\u2500 TITLE \u2500\u2500 */\n  .so-title { text-align: center; font-size: 16px; font-weight: bold; padding: 8px 0; border-bottom: 1px solid #000; }\n\n  /* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n     SECTION 1 \u2014 HEADER / ADDRESS TABLE\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n  .hdr-table { width: 100%; border-collapse: collapse; }\n  .hdr-table td { padding: 3px 6px; border: none; }\n\n  .hdr-table .lbl  { width: 15%; font-weight: bold; white-space: nowrap; }\n  .hdr-table .lval { width: 35%; }\n  .hdr-table .rlbl { width: 15%; font-weight: bold; white-space: nowrap;border-left:1px solid black; }\n  .hdr-table .rval { width: 35%; }\n\n  /* Bill-To / Ship-To grey header strip */\n  .addr-head td {\n    background: #D3D3D3;\n    text-align: center;\n    font-weight: bold;\n    padding: 5px 6px;\n    border-top: 1px solid #000;\n    border-bottom: 1px solid #000;\n  }\n  .addr-head td.right-cell { border-left: 1px solid #000; }\n\n  /* divider between meta rows and address rows */\n  .addr-data td { padding: 4px 6px; vertical-align: top; }\n  .addr-data td.right-cell { border-left: 1px solid #000; }\n\n  /* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n     SECTION 2 \u2014 ITEMS TABLE\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n  .items-table { width: 100%; border-collapse: collapse; border-top: 1px solid #000; }\n  .items-table th, .items-table td { border-left: 1px solid #000; padding: 4px 6px; }\n  .items-table th:first-child, .items-table td:first-child { border-left: none; }\n\n  .items-table thead tr th {\n    background: #D3D3D3;\n    text-align: center;\n    font-weight: bold;\n    border-top: 1px solid #000;\n    border-bottom: 1px solid #000;\n  }\n  .items-table .c  { text-align: center; }\n  .items-table .r  { text-align: right; white-space: nowrap; }\n\n  /* filler empty rows */\n  .items-table .filler td { border-top: none; border-bottom: none; height: 18px; }\n\n  /* total row */\n  .items-table .total-row td { border-top: 1px solid #000; font-weight: bold; }\n\n  /* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n     SECTION 3 \u2014 SUMMARY BLOCK\n  \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */\n  .summary-wrap { display: table; width: 100%; border-collapse: collapse; border-top: 1px solid #000; }\n  .sum-left  { display: table-cell; width: 50%; vertical-align: top; border-right: 1px solid #000; padding: 6px; }\n  .sum-right { display: table-cell; width: 50%; vertical-align: top; }\n\n  .sum-words { border-bottom: 1px solid #000; padding-bottom: 6px; margin-bottom: 6px; }\n\n  /* right-side totals mini-table */\n  .totals-tbl { width: 100%; border-collapse: collapse; }\n  .totals-tbl td { padding: 4px 8px; }\n  .totals-tbl .tot-lbl { text-align: right; font-weight: bold; border-bottom: 1px solid #000; }\n  .totals-tbl .tot-val { text-align: right; font-weight: bold; border-left: 1px solid #000; border-bottom: 1px solid #000; white-space: nowrap; }\n  .totals-tbl .tot-lbl.last { border-bottom: none; }\n  .totals-tbl .tot-val.last { border-bottom: none; }\n\n  /* \u2500\u2500 GST BREAKUP \u2500\u2500 */\n  .gst-table { width: 100%; border-collapse: collapse; border-top: 1px solid #000; }\n  .gst-table td { border: 1px solid #000; padding: 4px 6px; }\n\n  .footer-table { width: 100%; border-collapse: collapse; border-top: 1px solid #000; }\n  .footer-table td { padding: 6px; vertical-align: top; border: none; }\n  .footer-table .sig-cell { text-align: center; border-left: 1px solid #000; width: 35%; }\n</style>\n</head>\n<body>\n\n<div class=\"so-wrap\">\n                    <div>\n                        {% if letter_head %}\n                            {{ letter_head }}\n                        {% else %}\n                        {% endif %}\n                    </div>\n  <!-- \u2500\u2500 TITLE \u2500\u2500 -->\n  <div class=\"so-title\">SALES ORDER</div>\n\n  <table class=\"hdr-table\" style='line-height:0.1'>\n\n    <tr>\n      <td class=\"lbl\">Voucher No.</td>\n      <td class=\"lval\">: <b>{{ doc.name }}</b></td>\n      <td class=\"rlbl\">Customer's PO No.</td>\n      <td class=\"rval\">: <b>{{ doc.po_no or '' }}</b></td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">Dated</td>\n      <td class=\"lval\">: <b>{{ doc.get_formatted(\"transaction_date\") }}</b></td>\n      <td class=\"rlbl\">Customer's PO Date</td>\n      <td class=\"rval\">: <b>{{ doc.get_formatted(\"po_date\") }}</b></td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">Delivery Date</td>\n      <td class=\"lval\">: <b>{{ doc.get_formatted(\"delivery_date\") }}</b></td>\n      <td class=\"rlbl\">Payment Terms</td>\n      <td class=\"rval\">: {{ doc.payment_terms_template or '' }}</td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">Dispatched Through</td>\n      <td class=\"lval\">: {{ doc.transporter_name or '' }}</td>\n      <td class=\"rlbl\">Destination</td>\n      <td class=\"rval\">: {{ doc.shipping_address_name or '' }}</td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">Terms of Delivery</td>\n      <td class=\"lval\">: {{ doc.incoterm or '' }}</td>\n      <td class=\"rlbl\"></td>\n      <td class=\"rval\"></td>\n    </tr>\n\n    <!-- Bill To / Ship To header -->\n    <tr class=\"addr-head\">\n      <td colspan=\"2\"><b>Bill To Recipient</b></td>\n      <td colspan=\"2\" class=\"right-cell\"><b>Ship to Party</b></td>\n    </tr>\n\n    <!-- Buyer / Consignee -->\n    <tr class=\"addr-data\">\n      <td class=\"lbl\">Buyer</td>\n      <td>: <b>{{ doc.customer_name or '' }}</b></td>\n      <td class=\"lbl right-cell\">Consignee</td>\n      <td>: <b>{{ doc.customer_name or '' }}</b></td>\n    </tr>\n\n    <!-- Address -->\n    <tr class=\"addr-data\">\n      <td class=\"lbl\" style=\"vertical-align:top;\">Address</td>\n      <td style=\"vertical-align:top; line-height:1.4; word-break:break-word; white-space:normal;\">\n        :\n        {% if doc.customer_address %}\n          <b>{{ frappe.db.get_value('Address', doc.customer_address, \"address_title\") }}</b><br>\n          {{ doc.address_display or '' }}\n        {% endif %}\n      </td>\n      <td class=\"lbl right-cell\" style=\"vertical-align:top;\">Address</td>\n      <td style=\"vertical-align:top; line-height:1.4; word-break:break-word; white-space:normal;\">\n        :\n        {% if doc.shipping_address_name %}\n          <b>{{ frappe.db.get_value('Address', doc.shipping_address_name, \"address_title\") }}</b><br>\n          {{ doc.shipping_address or '' }}\n        {% endif %}\n      </td>\n    </tr>\n\n  </table>\n  \n  <table class=\"items-table\">\n    <thead>\n      <tr>\n        <th style=\"width:4%;\">Sr.No.</th>\n        <th>Description Of Goods</th>\n        <th style=\"width:8%;\">HSN/SAC Code</th>\n        <th style=\"width:5%;\">Qty</th>\n        <th style=\"width:5%;\">UOM</th>\n        <th style=\"width:9%;\">Rate</th>\n        <th style=\"width:6%;\">Disc%</th>\n        <th style=\"width:10%;\">Amount</th>\n      </tr>\n    </thead>\n    <tbody>\n\n      {% for item in doc.items %}\n      <tr>\n        <td class=\"c\">{{ loop.index }}</td>\n        <td>\n          <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n        <td class=\"c\">{{ item.gst_hsn_code or '' }}</td>\n        <td class=\"c\">{{ item.qty or '0' }}</td>\n        <td class=\"c\">{{ item.uom }}</td>\n        <td class=\"r\">{{ item.get_formatted(\"rate\") or '' }}</td>\n        <td class=\"c\">{{ item.discount_percentage or '0.00' }}</td>\n        <td class=\"r\">{{ item.get_formatted(\"amount\") }}</td>\n      </tr>\n      {% endfor %}\n\n      <!-- filler rows to minimum 5 lines -->\n      {% set total = doc.items|length %}\n      {% if total < 5 %}\n        {% for i in range(5 - total) %}\n        <tr class=\"filler\">\n          <td></td><td></td><td></td><td></td>\n          <td></td><td></td><td></td><td></td>\n        </tr>\n        {% endfor %}\n      {% endif %}\n\n      <!-- Total row -->\n      <tr class=\"total-row\">\n        <td></td>\n        <td style=\"text-align:right;\"><b>Total</b></td>\n        <td></td>\n        <td class=\"c\"><b>{{ doc.items|sum(attribute='qty') }}</b></td>\n        <td></td>\n        <td></td>\n        <td></td>\n        <td></td>\n      </tr>\n\n    </tbody>\n  </table>\n  <!-- END SECTION 2 -->\n\n\n  <div class=\"summary-wrap\">\n\n    <div class=\"sum-left\">\n      <div class=\"sum-words\">\n        Amount Chargeable (in words):<br>\n        <b>{{ doc.in_words }}</b>\n      </div>\n      <div>\n        <b>Bank Details:</b><br>\n        {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1,\"company\":doc.company}, \"name\") %}\n        {% if bank %}\n          {% set ba = frappe.get_doc(\"Bank Account\", bank) %}\n          {{ ba.bank }}<br>\n          A/C No: {{ ba.bank_account_no or '' }}<br>\n          IFSC: {{ ba.custom_ifsc or '' }}<br>\n          SWIFT: {{ frappe.db.get_value(\"Bank\", ba.bank, \"swift_number\") or '' }}\n        {% endif %}\n      </div>\n    </div>\n\n    <div class=\"sum-right\">\n      <table class=\"totals-tbl\">\n\n        <tr>\n          <td class=\"tot-lbl\">Taxable Amount :</td>\n          <td class=\"tot-val\">{{ doc.get_formatted(\"total\") }}</td>\n        </tr>\n\n        {% for row in doc.taxes %}\n        <tr>\n          <td class=\"tot-lbl\">Output Tax {{ row.description }} @ {{ row.rate }}% :</td>\n          <td class=\"tot-val\">{{ row.get_formatted(\"tax_amount\") }}</td>\n        </tr>\n        {% endfor %}\n\n        {% if doc.additional_discount_percentage %}\n        <tr>\n          <td class=\"tot-lbl\">Additional Discount % :</td>\n          <td class=\"tot-val\">{{ doc.get_formatted(\"additional_discount_percentage\") }}%</td>\n        </tr>\n        {% endif %}\n\n        {% if doc.discount_amount %}\n        <tr>\n          <td class=\"tot-lbl\">Additional Discount Amt :</td>\n          <td class=\"tot-val\">{{ doc.get_formatted(\"discount_amount\") }}</td>\n        </tr>\n        {% endif %}\n\n        <tr>\n          <td class=\"tot-lbl\">Round Off :</td>\n          <td class=\"tot-val\">{{ doc.get_formatted(\"rounding_adjustment\") }}</td>\n        </tr>\n\n        <tr>\n          <td class=\"tot-lbl last\">Total Amount After Tax :</td>\n          <td class=\"tot-val last\">\n            {{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}\n          </td>\n        </tr>\n\n      </table>\n    </div>\n\n  </div>\n  <!-- END SECTION 3 -->\n\n\n  {% if doc.gst_breakup_table %}\n  <table class=\"gst-table\">\n    <tr><td colspan=\"3\">{{ doc.gst_breakup_table }}</td></tr>\n    <tr>\n      <td width=\"30%\">Tax Amount (in words):</td>\n      <td width=\"40%\" style=\"text-align:center;\">\n        <b>Certified that the particulars given above are true</b>\n      </td>\n      <td></td>\n    </tr>\n    <tr>\n      <td><b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b></td>\n      <td></td>\n      <td></td>\n    </tr>\n  </table>\n  {% endif %}\n\n\n \n  <table class=\"footer-table\">\n    <tr>\n      <td>\n        <strong>Terms &amp; Conditions :</strong><br>\n        {{ doc.terms or '' }}\n      </td>\n      <td class=\"sig-cell\">\n        <b>For, {{ doc.company }}</b>\n        <br><br><br><br><br><br><br><br>\n        Authorised Signatory\n      </td>\n    </tr>\n  </table>\n\n</div><!-- end .so-wrap -->\n\n</body>\n</html>",
