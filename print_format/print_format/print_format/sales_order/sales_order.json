 "doc_type": "Sales Order",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\ntable {\n        margin-left: auto;\n        margin-right: auto;\n        width: 100%;\n        font-size: 10px;\n        border: 1px solid black;\n        border-collapse: collapse;\n    }\n    td {\n        border: 1px solid black;\n        text-align: left;\n        font-size: 10px;\n    }\n    \n\n.print-format .letter-head {\n    margin-bottom: -1px;\n}\n .item-row td { border-top:1px solid black!important; }\n    .wrap{\n        white-space:nowrap;\n    }\n    html, body {\n    margin: 0;\n    padding: 0;\n}\n * {\n    font-size: 11px;\n    font-family: Arial, sans-serif;\n  }\n  thead tr th { text-align: center; }\n  .center { text-align: center; }\n  .right  { text-align: right; }\n  .items-header {\n    background-color: #f0f0f0;\n    font-weight: bold;\n    font-size: 9pt;\n    \n  }\n  .item-row td {  }\n  .total-row { font-weight: bold; }\n  .amount-words { font-weight: bold;  }\n  .footer-note { text-align: center; font-size: 9pt; }\n\n  .main-div { display: table; width: 100%; border-collapse: collapse; border: 1px solid #000; }\n  .main-div-row { display: table-row; }\n  .left-div {\n    display: table-cell;\n    width: 50%;\n    vertical-align: top;\n    padding: 0;\n    border-right: 1px solid #000;\n  }\n  .right-div {\n    display: table-cell;\n    width: 50%;\n    vertical-align: top;\n    padding: 0;\n  }\n\n  .left-table {\n    width: 100%;\n    border-collapse: collapse;\n}\n.left-table,\n.left-table tr,\n.left-table td {\n    border: none !important;\n}\n.left-div {\n    border-right: 1px solid #000; \n}\n.left-table tr:first-child td {\n    border-bottom: none !important;\n}\n.left-table tr:nth-child(2) td {\n    border-top: 1px solid #000 !important;\n}\n.meta-table {\n    width: 100%;\n    border-collapse: collapse !important;\n    border: none !important;\n}\n\n.meta-table,\n.meta-table tr,\n.meta-table td,\n.meta-table tbody {\n    border: none !important;\n}\n\n/* Remove Frappe default table border */\n.meta-table table {\n    border: none !important;\n}\n.meta-table td:nth-child(1) {\n    border-right: 1px solid #000;\n    font-weight: bold;\n}\n\n\n.meta-table td:nth-child(1)::after {\n    content: \" :\";\n}\n</style>\n\n\n<div>\n     <div class=\"letter-head\">\n        {% if letter_head %}\n            {{ letter_head }}\n           {% endif %}\n    </div>\n\n  <table border=\"0\" width=\"100%\">\n    <tr>\n      <td style=\"text-align:center; font-size:16px; font-weight:bold; padding:8px 0;\">\n        SALES ORDER\n      </td>\n    </tr>\n  </table>\n\n  <!-- HEADER -->\n  <div class=\"main-div\">\n    <div class=\"main-div-row\">\n\n      <!-- LEFT -->\n      <div class=\"left-div\">\n        <table class=\"left-table\">\n          <tr>\n            <td style=\"border-bottom:1px solid black; padding:5px 8px; line-height:1.6;\">\n              <span style=\"font-size:12px; font-weight:bold;\">{{ doc.company }}</span><br>\n              {% if doc.company_address %}\n                {% set ca = frappe.get_doc(\"Address\", doc.company_address) %}\n                {{ ca.address_line1 or \"\" }}<br>\n                {% if ca.address_line2 %}{{ ca.address_line2 }}<br>{% endif %}\n                {{ ca.city or \"\" }}<br>\n                GSTIN/UIN : {{ ca.gstin or \"\" }}<br>\n                State Name : {{ ca.state or \"\" }}, Code : {{ ca.gst_state_number or \"\" }}\n              {% endif %}\n            </td>\n          </tr>\n          <tr>\n            <td style=\"padding:5px 8px; line-height:1;\">\n              <span style=\"font-weight:bold;\">Invoice to :</span><br>\n              <span style=\"font-size:12px; font-weight:bold;\">{{ doc.customer_name }}</span><br>\n              {% if doc.customer_address %}\n                {% set caddr = frappe.get_doc(\"Address\", doc.customer_address) %}\n                {{ caddr.address_line1 or \"\" }}<br>\n                {% if caddr.address_line2 %}{{ caddr.address_line2 }}<br>{% endif %}\n                {{ caddr.city or \"\" }}<br>\n                GSTIN/UIN : {{ caddr.gstin or \"\" }}<br>\n                State Name : {{ caddr.state or \"\" }}, Code : {{ caddr.gst_state_number or \"\" }}\n              {% else %}\n                {{ doc.address_display or \"\" }}\n              {% endif %}\n            </td>\n          </tr>\n        </table>\n      </div>\n\n      <div class=\"right-div\">\n        <table class=\"meta-table\">\n          <tr><td>Voucher No.</td><td>{{ doc.name }}</td></tr>\n          <tr><td>Dated</td><td>{{ doc.get_formatted(\"transaction_date\") }}</td></tr>\n          <tr><td>Customer's PO No.</td><td>{{ doc.po_no or \"\" }}</td></tr>\n          <tr><td>Customer's PO Date</td><td>{{ doc.get_formatted(\"po_date\") }}</td></tr>\n          <tr><td>Delivery Date</td><td>{{ doc.get_formatted(\"delivery_date\") }}</td></tr>\n          <tr><td>Payment Terms</td><td>{{ doc.payment_terms_template or \"\" }}</td></tr>\n          <tr><td>Dispatched Through</td><td>{{ doc.transporter_name or \"\" }}</td></tr>\n          <tr><td>Destination</td><td>{{ doc.shipping_address_name or \"\" }}</td></tr>\n          <tr><td>Terms of Delivery</td><td>{{ doc.incoterm or \"\" }}</td></tr>\n        </table>\n      </div>\n\n    </div>\n  </div>\n{% set has_igst = 0 %}\n{% set has_cgst_sgst = 0 %}\n\n{% for item in doc.items %}\n  {% if item.igst_rate and item.igst_rate > 0 %}\n    {% set has_igst = 1 %}\n  {% elif (item.cgst_rate and item.cgst_rate > 0) or (item.sgst_rate and item.sgst_rate > 0) %}\n    {% set has_cgst_sgst = 1 %}\n  {% endif %}\n{% endfor %}\n\n        <table width='100%' class = \"mt\">\n                                        <thead>\n                                            <tr>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">Sr.No.</td>\n                                                <td class=\"desc-col\" style=\"background-color:#D3D3D3;text-align:center;\">Description Of Goods</td>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">HSN/SAC Code</td>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">Qty</td>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">UOM</td>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:7%;\">Rate</td>\n                                                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">Disc%</td>\n                                                <td style=\"background-color:#D3D3D3;\n                                                           text-align:center;\n                                                           width:10%;\n                                                           border-right:1px solid black\">Amount</td>\n                                            </tr>\n                                        </thead>\n                                        <tbody>\n                                            {% for item in doc.items %}\n                                                <tr>\n                                                    <td style=\"text-align:center\">{{ loop.index }}</td>\n                                                    <td>   <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n                                                    <td style=\"text-align:center;\">{{ item.gst_hsn_code or '' }}</td>\n                                                    <td style=\"text-align:center;\">{{ item.qty or '0' }}</td>\n                                                    <td style=\"text-align:center;\">{{ item.uom }}</td>\n                                                    <td style=\"text-align:right;white-space:nowrap\">{{ item.get_formatted(\"rate\") or '' }}</td>\n                                                    <td style=\"text-align:center;\">{{ item.discount_percentage or '0.00' }}</td>\n                                                    <td style=\"text-align:right;\n                                                               white-space:nowrap;\n                                                               border-right:1px solid black\">\n                                                        {{ item.get_formatted(\"amount\") }}\n                                                    </td>\n                                                </tr>\n                                            {% endfor %}\n                                            {% set total = doc.items|length %}\n                                            {% if total < 5 %}\n                                                {% for i in range(5- total) %}\n                                                    <tr class=\"filler-row\">\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;border-left:1px solid #000\"></td>\n                                                        <td style=\"border:none;\n                                                                   border-left:1px solid #000;\n                                                                   border-right:1px solid black\"></td>\n                                                    </tr>\n                                                {% endfor %}\n                                            {% endif %}\n                                            <tr class=\"row-header\" style=\"border-top:1px solid black;\">\n                                                <td style=\"border-left:1px solid black;border-top:1px solid black;\"></td>\n                                                <td style=\"text-align:right;\n                                                           border-left:1px solid black;\n                                                           border-top:1px solid black\">\n                                                    <b>Total</b>\n                                                </td>\n                                                <td style=\"border-left:1px solid black;border-top:1px solid black;\"></td>\n                                                <td style=\"text-align:center;\n                                                           border-left:1px solid black;\n                                                           border-top:1px solid black\">\n                                                    <b>{{ doc.items|sum(attribute='qty') }}</b>\n                                                </td>\n                                                <td style=\"border-left:1px solid black;border-top:1px solid black;\"></td>\n                                                <td style=\"border-left:1px solid black;border-top:1px solid black;\"></td>\n                                                <td style=\"border-top:1px solid black;\"></td>\n                                                <td style=\"text-align:right;\n                                                           white-space:nowrap;\n                                                           border-left:1px solid black;\n                                                           border-top:1px solid black\"></td>\n                                            </tr>\n                                        </tbody>\n                                        <tfoot>\n                                            <tr class=\"row-header\">\n                                                <td></td>\n                                                <td style='text-align:right'></td>\n                                                <td></td>\n                                                <td style='text-align:center'></td>\n                                                <td></td>\n                                                <td></td>\n                                                <td></td>\n                                                <td style=\"text-align:right;\n                                                           white-space:nowrap;\n                                                           border-right:1px solid black\"></td>\n                                            </tr>\n                                        </tfoot> {% set tax_count = doc.taxes|length %}\n                                    </table>\n                                    <!-- ===== SUMMARY BLOCK \u2014 page-break-inside: avoid keeps it together ===== -->\n                                    <div class=\"summary-block\"\n                                         style=\"width:100%;\n                                                border:1px solid #000;\n                                                font-size:10px;\n                                                display:table;\n                                                border-collapse:collapse\">\n                                        <!-- LEFT SIDE -->\n                                        <div style=\"display:table-cell;\n                                                    width:34.2%;\n                                                    border-right:1px solid #000;\n                                                    vertical-align:top\">\n                                            <div style=\"padding:5px; border-bottom:1px solid #000;\">\n                                                Amount Chargeable (in words) :\n                                                <br>\n                                                <b>{{ doc.in_words }}</b>\n                                            </div>\n                                            <div style=\"padding:6px;\">\n                                                <div style=\"display:table; width:100%;\">\n                                                    <div style=\"display:table-cell; width:25%; vertical-align:top;\">\n                                                        <b>Bank Details:</b>\n                                                    </div>\n                                                    <div style=\"display:table-cell; vertical-align:top;\">\n                                                        {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1,\"company\":doc.company},\"name\") %}\n                                                        {% if bank %}\n                                                            {% set bank_add = frappe.get_doc(\"Bank Account\", bank) %} {{ bank_add.bank }}\n                                                            <br>\n                                                            A/C No: {{ bank_add.bank_account_no or '' }}\n                                                            <br>\n                                                            IFSC: {{ bank_add.custom_ifsc or '' }}\n                                                            <br>\n                                                            SWIFT: {{ frappe.db.get_value(\"Bank\", bank_add.bank, \"swift_number\") or '' }}\n                                                        {% endif %}\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <!-- RIGHT SIDE -->\n                                        <div style=\"display:table-cell; width:34%; vertical-align:top;\">\n                                            <div style=\"display:table;\n                                                        width:100%;\n                                                        border-collapse:collapse\"\n                                                 class=\"main\">\n                                                <div style=\"display:table-row;\">\n                                                    <div style=\"display:table-cell;\n                                                                padding:6px 10px;\n                                                                text-align:right;\n                                                                border-bottom:1px solid #000\">\n                                                        <b>Taxable Amount :</b>\n                                                    </div>\n                                                    <div style=\"display:table-cell;\n                                                                padding:6px 10px;\n                                                                text-align:right;\n                                                                border-bottom:1px solid #000;\n                                                                border-left:1px solid #000;\n                                                                white-space:nowrap\">\n                                                        <b>{{ doc.get_formatted(\"total\") }}</b>\n                                                    </div>\n                                                </div>\n                                                {% if doc.taxes and doc.taxes|length > 0 %}\n                                                    {% for row in doc.taxes %}\n                                                        <div style=\"display:table-row;\">\n                                                            <div style=\"display:table-cell;\n                                                                        padding:6px 10px;\n                                                                        text-align:right;\n                                                                        border-bottom:1px solid #000\">\n                                                                <b>Output Tax {{ row.description }} @ {{ row.rate }}% :</b>\n                                                            </div>\n                                                            <div style=\"display:table-cell;\n                                                                        padding:6px 10px;\n                                                                        text-align:right;\n                                                                        border-bottom:1px solid #000;\n                                                                        border-left:1px solid #000;\n                                                                        white-space:nowrap\">\n                                                                <b>{{ row.get_formatted(\"tax_amount\") }}</b>\n                                                            </div>\n                                                        </div>\n                                                    {% endfor %}\n                                                {% endif %}\n                                                {% if doc.additional_discount_percentage %}\n                                                    <div style=\"display:table-row;\">\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000\">\n                                                            <b>Additional Discount Percentage:</b>\n                                                        </div>\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000;\n                                                                    border-left:1px solid #000;\n                                                                    white-space:nowrap\">\n                                                            <b>{{ doc.get_formatted(\"additional_discount_percentage\") }}%</b>\n                                                        </div>\n                                                    </div>\n                                                    <div style=\"display:table-row;\">\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000\">\n                                                            <b>Additional Discount Amount:</b>\n                                                        </div>\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000;\n                                                                    border-left:1px solid #000;\n                                                                    white-space:nowrap\">\n                                                            <b>{{ doc.get_formatted(\"discount_amount\") }}</b>\n                                                        </div>\n                                                    </div>\n                                                {% endif %}\n                                                {% if (not doc.additional_discount_percentage) and doc.discount_amount %}\n                                                    <div style=\"display:table-row;\">\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000\">\n                                                            <b>Additional Discount Amount:</b>\n                                                        </div>\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid #000;\n                                                                    border-left:1px solid #000;\n                                                                    white-space:nowrap\">\n                                                            <b>{{ doc.get_formatted(\"discount_amount\") }}</b>\n                                                        </div>\n                                                    </div>\n                                                {% endif %}\n                                                <div style=\"display:table-row;\">\n                                                    <div style=\"display:table-cell;\n                                                                padding:6px 10px;\n                                                                text-align:right;\n                                                                border-bottom:1px solid #000\">\n                                                        <b>Round off :</b>\n                                                    </div>\n                                                    <div style=\"display:table-cell;\n                                                                padding:6px 10px;\n                                                                text-align:right;\n                                                                border-bottom:1px solid #000;\n                                                                border-left:1px solid #000;\n                                                                white-space:nowrap\">\n                                                        <b>{{ doc.get_formatted(\"rounding_adjustment\") }}</b>\n                                                    </div>\n                                                </div>\n                                                {% if doc.additional_discount_percentage or doc.discount_amount %}\n                                                    <div style=\"display:table-row;\">\n                                                        <div style=\"display:table-cell; padding:6px 10px; text-align:right;\">\n                                                            <b>Total Amount After Tax:</b>\n                                                        </div>\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    white-space:nowrap;\n                                                                    border-left:1px solid #000\">\n                                                            <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n                                                        </div>\n                                                    </div>\n                                                {% else %}\n                                                    <div style=\"display:table-row;\">\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    border-bottom:1px solid black\">\n                                                            <b>Total Amount After Tax:</b>\n                                                        </div>\n                                                        <div style=\"display:table-cell;\n                                                                    padding:6px 10px;\n                                                                    text-align:right;\n                                                                    white-space:nowrap;\n                                                                    border-left:1px solid #000;\n                                                                    border-bottom:1px solid black;\n                                                                    border-left:1px solid black\">\n                                                            <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n                                                        </div>\n                                                    </div>\n                                                {% endif %}\n                                            </div>\n                                        </div>\n                                    </div>\n                                    <table class='gt'>\n                                        {% if doc.gst_breakup_table %}\n                                            <tr class='mt1'>\n                                                <td colspan=\"3\">{{ doc.gst_breakup_table or '' }}</td>\n                                            </tr>\n                                        {% endif %}\n                                        <tr>\n                                            <td width=29% style=\"border-bottom:none;\">Tax Amount (in words) :</td>\n                                            <td width=39% rowspan=\"2\">\n                                                <center>\n                                                    <br>\n                                                    <b>Certified that the particulars given above are true</b></center>\n                                            </td>\n                                        </tr>\n                                        <tr>\n                                            <td style=\"width:39%;border-top:none;\">\n                                                <b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\n                                            </td>\n                                        </tr>\n                                    </table>\n                                    <table style=\"width:100%; table-layout:fixed;\">\n                                        <tr>\n                                            <!-- Terms -->\n                                            <td style=\"width:20.6%; text-align:left; vertical-align:top;\">\n                                                <strong>Terms &amp; Conditions :</strong>\n                                                <br>\n                                                {{ doc.terms or '' }}\n                                            </td>\n                                            <!-- QR Code -->\n                                            <td style=\"width:10.33%; position:relative;\">\n                                                {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", {\"reference_name\": doc.name}, [\"signed_qr_code\"], as_dict=1) %}\n                                                {% if e_invoice_log %}\n                                                    <div style=\"position:absolute;\n                                                                top:37px;\n                                                                left:50%;\n                                                                transform:translateX(-50%)\">\n                                                        <div style=\"width:90px;\n                                                                    height:90px;\n                                                                    border:1px solid #000;\n                                                                    display:flex;\n                                                                    align-items:center;\n                                                                    justify-content:center\">\n                                                            <img src=\"data:image/png;base64,{{ get_qr_code(e_invoice_log.signed_qr_code, scale=4) }}\"\n                                                                 style=\"max-width:100%;\n                                                                        max-height:100%;\n                                                                        object-fit:contain\">\n                                                        </div>\n                                                    </div>\n                                                {% endif %}\n                                            </td>\n                                            <!-- Signature -->\n                                            <td style=\"width:10.33%; text-align:center; vertical-align:top;\">\n                                                <b>For, <strong>{{ doc.company }}</strong></b>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                <br>\n                                                Authorised Signatory\n                                            </td>\n                                        </tr>\n                                    </table>\n                        \n</div>\n</body>\n</html>",
