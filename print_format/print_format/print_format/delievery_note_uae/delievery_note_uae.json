 "doc_type": "Delivery Note",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  .fit-to-page {\n    zoom: 0.80;\n    transform: scale(0.95);\n    transform-origin: top left;\n    width: 100%;\n  }\n  .lb{\n      border-bottom:1px solid black;\n  }\n.lbl::after { content: \" :\"; }\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { font-family: Arial, sans-serif; font-size: 11px; background: white; color: #000; -webkit-print-color-adjust: exact; }\n table { border:1; width: 100%; }\n  .mb { border: 1px solid #000; }\n  .items-table th { background-color: #f0f0f0; text-align: center; font-size: 10px;  font-weight: bold; }\n  .text-center { text-align: center; }\n  .text-right  { text-align: right; }\n  .bold        { font-weight: bold; }\n  .grand-total { font-size: 12px; font-weight: bold; background-color: #f0f0f0; }\n  .company-name { font-size: 14px; font-weight: bold; }\n  .bottom-note { text-align: center; font-size: 10px; border: 1px solid #000; border-top: none; padding: 4px; font-weight: bold; }\n  /* CHECK TABLE */\n  .check tr td { border: none; padding: 3px 6px; }\n  .check tr td:nth-child(3) { border-left: 1px solid #000; }\n  .check tr td:nth-child(3),\n  .check tr td:nth-child(1) { font-weight: bold; }\n  /* INFO TABLE */\n  .info-table { border: none; width: 100%; border-collapse: collapse; border-top: none; }\n  .info-table td { padding: 3px 6px; vertical-align: top; font-size: 10.5px; }\n  /* MAIN DIV \u2014 PDF safe display:table */\n  .main-div { display: table; width: 100%; border-collapse: collapse; border: 1px solid #000; border-top: none; }\n  .main-div-row { display: table-row; }\n  .left-div { display: table-cell; width: 40%; vertical-align: top; padding: 6px; border-right: 1px solid #000; }\n  .right-div { display: table-cell; width: 60%; vertical-align: top; padding: 0; }\n  .city td { border-bottom: 1px solid black; }\n  .totals-table { width: 100%; border-collapse: collapse; border: 1px solid #000; border-top: none; }\n  .totals-table td { border: 1px solid #000; padding: 3px 8px; font-size: 10.5px; }\n</style>\n</head>\n<body>\n<div class=\"fit-to-page\">\n\n  <!-- LETTER HEAD -->\n  <div>\n    {% if letter_head %}{{ letter_head }}{% endif %}\n  </div>\n\n  <!-- TITLE -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"text-align:center; font-size:16px; font-weight:bold; padding:6px 10px;\">\n        {{ _(\"Delivery Note\") }}\n      </td>\n    </tr>\n  </table>\n\n  <!-- COMPANY INFO -->\n\n  <!-- MAIN DIV: Buyer (left) + DN Meta (right) -->\n  <div class=\"main-div\">\n    <div class=\"main-div-row\">\n\n      <!-- LEFT: Buyer + Ship To -->\n      <div class=\"left-div\">\n        <div><b>{{ _(\"Buyer\") }} :</b></div>\n        <div>{{ doc.customer_name }}</div>\n        {{ doc.address_display or \"\" }}\n        {% set ba = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None %}\n        {% if ba %}\n          <div>{{ _(\"TRN\") }} : {{ ba.gstin or \"\" }}</div>\n        {% endif %}\n        \n      </div>\n\n      <!-- RIGHT: Delivery Note Meta \u2014 DN fields only -->\n      <div class=\"right-div\">\n        <table class=\"info-table check\">\n          <tr>\n            <td>{{ _(\"Delivery Note No.:\") }}</td>\n            <td>{{ doc.name }}</td>\n            <td>{{ _(\"Dated :\") }}</td>\n            <td>{{ doc.get_formatted(\"posting_date\") }}</td>\n          </tr>\n          <tr>\n            <td>{{ _(\"Customer :\") }}</td>\n            <td>{{ doc.customer_name }}</td>\n            <td>{{ _(\"Customer's Purchase Order No.:\") }}</td>\n            <td>{{ doc.po_no or \"\" }}</td>\n          </tr>\n          <tr>\n              <td>{{ _(\"Dispatched Through:\") }}</td>\n            <td>{{ doc.transporter_name or \"\" }}</td>\n           \n           \n            </td>\n            <td>{{ _(\"Delivery Date:\") }}</td>\n            <td>{{ doc.get_formatted(\"posting_date\") }}</td>\n          </tr>\n          <tr>\n              <td>{{ _(\"Driver Name:\") }}</td>\n            <td>{{ doc.driver_name or \"\" }}</td>\n           <td>{{ _(\"Vehicle No:\") }}</td>\n            <td>{{ doc.vehicle_no or \"\" }}</td>\n          </tr>\n          <tr class='lb'>\n            \n            <td>{{ _(\"Mode of Transport:\") }}</td>\n            <td>{{ doc.mode_of_transport or \"\" }}</td>\n            <td>\n               \n            </td>\n             <td></td>\n          </tr>\n          <tr>\n            <td style=\"white-space:nowrap;\" colspan=\"4\">\n              <b>{{ _(\"Terms of Delivery\") }} :</b>\n              {{ doc.incoterm or \"\" }}\n            </td>\n          </tr>\n        </table>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- ITEMS TABLE \u2014 same as SO -->\n  <table class=\"items-table\" border=1>\n    <thead>\n      <tr>\n        <th style=\"\">{{ _(\"Sr No.\") }}</th>\n        <th style=\"\">{{ _(\"Item Code\") }}</th>\n        <th>{{ _(\"Description of Goods\") }}</th>\n        <th style=\"\">{{ _(\"Quantity\") }}</th>\n        <th style=\"white-space:nowrap\">{{ _(\"Rate\") }}</th>\n        <th style=\"\">{{ _(\"Per\") }}</th>\n        <th style=\"\">{{ _(\"VAT\") }} %</th>\n        <th style=\"\">{{ _(\"Taxable Value\") }} {{ doc.currency }}</th>\n        <th style=\"\">{{ _(\"VAT Amount\") }} {{ doc.currency }}</th>\n        <th style=\"\">{{ _(\"Total Incl. VAT\") }} {{ doc.currency }}</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set vat_rate = namespace(value=5) %}\n      {% for tax in doc.taxes %}\n        {% if tax.charge_type == \"On Net Total\" %}\n          {% set vat_rate.value = tax.rate %}\n        {% endif %}\n      {% endfor %}\n      {% for item in doc.items %}\n      <tr>\n        <td class=\"text-center\">{{ loop.index }}</td>\n        <td>{{ item.item_code }}</td>\n        <td>\n          <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n        <td class=\"text-center\">{{ item.qty | int }}</td>\n        <td style=\"white-space:nowrap;\" class='text-right'>{{ item.get_formatted(\"rate\") }}</td>\n        <td class=\"text-center\">{{ item.uom }}</td>\n        <td class=\"text-center\">{{ vat_rate.value }}%</td>\n        <td class=\"text-right\">{{ item.get_formatted(\"amount\") }}</td>\n        <td class=\"text-right\">{{ frappe.utils.fmt_money(item.amount * vat_rate.value / 100, currency=doc.currency) }}</td>\n        <td class=\"text-right bold\">{{ frappe.utils.fmt_money(item.amount * (1 + vat_rate.value / 100), currency=doc.currency) }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n    <tfoot>\n      <tr>\n        <td colspan=\"3\" class=\"text-right bold\">{{ _(\"Total\") }}</td>\n        <td class=\"text-center bold\">\n          {% set total_qty = namespace(value=0) %}\n          {% for item in doc.items %}{% set total_qty.value = total_qty.value + item.qty %}{% endfor %}\n          {{ total_qty.value | int }}\n        </td>\n        <td colspan=\"3\"></td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"total\") }}</td>\n        <td class=\"text-right bold\">\n          {% set vat = namespace(value=0) %}\n          {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n          {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n        </td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"grand_total\") }}</td>\n      </tr>\n    </tfoot>\n  </table>\n\n  <!-- TOTALS BREAKDOWN \u2014 same as SO -->\n  <table class=\"totals-table\">\n    <tr>\n      <td style=\"width:55%; vertical-align:top;\">\n        <b>{{ _(\"Amount Chargeable (in words)\") }}</b><br>\n        {{ doc.in_words or \"\" }}\n        <br>\n        <b>{{ _(\"VAT Amount Chargeable (in words)\") }}</b><br>\n        {{ frappe.utils.money_in_words(doc.total, doc.currency) }}\n      </td>\n      <td style=\"width:45%;\">\n        <table style=\"width:100%; border-collapse:collapse;\">\n          <tr>\n            <td>{{ _(\"Taxable Value\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"total\") }}</td>\n          </tr>\n          <tr>\n            <td>{{ _(\"Value Added Tax\") }} {{ vat_rate.value }}%</td>\n            <td class=\"text-right\">\n              {% set vat = namespace(value=0) %}\n              {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n              {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n            </td>\n          </tr>\n          {% if doc.discount_amount %}\n          <tr>\n            <td>{{ _(\"Discount\") }}</td>\n            <td class=\"text-right\">(-{{ doc.get_formatted(\"discount_amount\") }})</td>\n          </tr>\n          {% endif %}\n          {% if doc.rounding_adjustment %}\n          <tr>\n            <td>{{ _(\"Rounded Off\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"rounding_adjustment\") }}</td>\n          </tr>\n          {% endif %}\n          <tr class=\"grand-total\">\n            <td><b>{{ _(\"Invoice Total\") }}</b></td>\n            <td class=\"text-right bold\">\n              <b>\n                {% if doc.disable_rounded_total %}\n                  {{ doc.get_formatted(\"grand_total\") }}\n                {% else %}\n                  {{ doc.get_formatted(\"rounded_total\") or doc.get_formatted(\"grand_total\") }}\n                {% endif %}\n              </b>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  <!-- FOOTER: Terms + Signatory \u2014 same as SO -->\n  <div style=\"width:100%; display:table; border:1px solid #000; border-top:none; border-collapse:collapse;\">\n    <div style=\"display:table-row;\">\n      <div style=\"display:table-cell; width:55%; padding:5px; vertical-align:top; border-right:1px solid #000;\">\n        <strong>Terms &amp; Conditions:</strong><br>\n        <div style=\"white-space:pre-wrap;\">{{ doc.terms or \"\" }}</div>\n      </div>\n      <div style=\"display:table-cell; width:25%; padding:5px; text-align:center; vertical-align:top;\">\n        <b>For, {{ doc.company }}</b>\n        <br><br><br><br>\n        Authorised Signatory\n      </div>\n    </div>\n  </div>\n\n  <!-- BOTTOM NOTE -->\n  <div class=\"bottom-note\">\n    {{ _(\"This is a Computer Generated Invoice\") }}\n  </div>\n\n</div>\n</body>\n</html>",
