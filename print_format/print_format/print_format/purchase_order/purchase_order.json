 "doctype": "Print Format",
 "font_size": 14,
 "html": "<html>\n    <head>\n    <style>\n      table {\n        margin-left: auto;\n        margin-right: auto;\n        width: 100%;\n        font-size: 10px;\n        border: 1px solid black;\n        border-collapse: collapse;\n    }\n    td {\n        border: 1px solid black;\n        text-align: left;\n        font-size: 10px;\n    }\n       td {\n    overflow: visible !important;\n  }\n\n.mt tbody tr {\n    height: 32px;          /* fixed height */\n    min-height: 32px;      /* safety */\n  }\n\n  /* \u2705 Filler rows same height */\n  .filler-row td {\n    height: 32px;\n  }\n\n  /* \u2705 Prevent collapsing in PDF */\n  .filler-row td:empty::after {\n    content: \"\\00a0\";   /* NBSP */\n  }\n\n  /* \u2705 Description wrapping */\n  .mt td:nth-child(2) {\n    word-break: break-word;\n  }\n\n  *::-webkit-scrollbar {\n    display: none;\n  }\n\n    .gt{\n        margin:0px !important;\n        padding:0px !important;\n    }\n       .table1 tr td:nth-child(4){\n        border-left:1px solid black !important;\n    }\n    .mt {\n        border-collapse: collapse !important;\n        border-spacing: 0 !important;\n    }\n    \n    .mt thead{\n        display: table-header-group;\n    }\n    .mt tfoot{\n        display: table-footer-group;\n    }\n  \n    .mt tr td{\n        padding:5px 6px !important;\n        border:none !important;\n        border-left:1px solid black !important;\n    }\n    \n    .mt thead tr td {\n        border-bottom: 1px solid #000 !important;\n    }\n    \n    .mt tbody tr:first-child td {\n        padding-top: 2px !important;\n    }\n    \n    .mt tr {\n        page-break-inside: avoid !important;\n        break-inside: avoid !important;\n    }\n    \n    .gt tbody .mt1{\n        margin:0px !important;\n        padding:0px !important;\n    }\n    .mt1 {\n        margin-bottom:10px;\n        padding:2px 5px !important;\n    }\n\n    .page-break {\n      page-break-after: always;\n      break-after: page;\n    }\n    \n    .fit-to-page {\n      width: 100%;\n      margin: 0;\n      padding: 0;\n    }\n    \n    .info-table {\n      border: 1px solid #000;\n      border-top: none;\n      font-size: 13px;\n    }\n    \n    .info-table td {\n      padding: 2px 4px;\n      border: none;\n      line-height:1.3;\n    }\n    \n    table{\n        border-collapse: collapse;\n    }\n    \n    .main {\n        border-collapse: collapse;\n    }\n    \n    .main td {\n        border: none !important;\n    }\n    \n    .main tr td:nth-child(1) {\n        border-bottom: 1px solid black !important;\n    }\n    \n    .main tr td:nth-child(2) {\n        border-bottom: 1px solid black !important;\n        border-left: 1px solid black !important;\n    }\n    \n    table thead tr td{\n        font-weight:bold;\n    }\n    \n    @page {\n        size: A4;\n        margin: 8mm 5mm 8mm 5mm; \n    }\n    \n    html, body {\n        margin: 0;\n        padding: 0;\n        font-family: Arial, sans-serif;\n        font-size: 11px;   \n        line-height: 1.15; \n        -webkit-print-color-adjust: exact;\n        background: white;\n    }\n    \n    .filler-row td {\n      height: 20px !important; \n      border-bottom: none !important;\n    }\n    \n    .mt {\n        border-bottom: 1px solid black !important;\n    }\n    </style>\n    </head>\n    <body>\n    \n    <div class='fit-to-page page-break'>\n    \n    {% set currency_symbol = frappe.db.get_value(\"Currency\", doc.currency, \"symbol\") %}\n    \n    <div class=tab-cont>\n      <div>\n        {% if letter_head %}\n        {{ letter_head }}\n        {% else %}\n        {% endif %}\n      </div>\n    </div>\n    \n    <!-- TITLE -->\n    <table style=\"width:100%;font-size:13px; line-height:0.4; border:1px solid #000; border-top:none;\">\n        <tr>\n            <td style=\"font-size:15px;background-color:#D3D3D3;padding:5px;\"><b><center>Purchase Order</center></b></td>\n        </tr>\n    </table>\n    \n    <!-- ADDRESSES -->\n    \n    <!-- PO DETAILS -->\n<table style=\"width:100%; border:1px solid #000; border-top:none; border-collapse:collapse; table-layout:fixed;\" class='table1'>\n\n    <colgroup>\n        <col style=\"width:18%\">  <!-- Label (PO No.) -->\n        <col style=\"width:2%\">   <!-- Colon -->\n        <col style=\"width:30%\">  <!-- Value -->\n        <col style=\"width:22%\">  <!-- Label (Mode of Dispatch) -->\n        <col style=\"width:2%\">   <!-- Colon -->\n        <col style=\"width:26%\">  <!-- Value -->\n    </colgroup>\n\n    <tr>\n        <td style=\"padding: 5px; border: none;\"><strong>PO No.</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\"><b>{{ doc.name or \"\" }}</b></td>\n        <td style=\"padding: 5px; border: none;\"><strong>Mode of Dispatch</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{doc.custom_mode_of_dispatch or ''}}</td>\n    </tr>\n    <tr>\n        <td style=\"padding: 5px; border: none;\"><strong>PO Date</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{ frappe.format_date(doc.transaction_date, \"dd-MM-yyyy\") if doc.transaction_date else \"\" }}</td>\n        <td style=\"padding: 5px; border: none;\"><strong>Payment Terms</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{ doc.payment_terms_template or \"\" }}</td>\n    </tr>\n    <tr>\n        <td style=\"padding: 5px; border: none;\"><strong>Quote Ref.</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{ doc.items[0].supplier_quotation or \"\" }}</td>\n        <td style=\"padding: 5px; border: none;\"><strong>Delivery Terms</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{doc.custom_delivery_terms or ''}}</td>\n    </tr>\n    <tr>\n        <td style=\"padding: 5px; border: none;\"><strong>Quote Date</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">\n            {% set quote = doc.items[0].supplier_quotation %}\n            {% if quote %}\n                {% set quote_date = frappe.db.get_value(\"Supplier Quotation\", quote, \"transaction_date\") %}\n                {% if quote_date %}\n                    {{ frappe.utils.formatdate(quote_date, \"dd-MM-yyyy\") }}\n                {% endif %}\n            {% endif %}\n        </td>\n        <td style=\"padding: 5px; border: none;\"><strong>Warranty Terms</strong></td>\n        <td style=\"padding: 5px; border: none;\">:</td>\n        <td style=\"padding: 5px; border: none;\">{{doc.custom_warranty_terms or ''}}</td>\n    </tr>\n</table> \n<table style=\"width:100%; border:1px solid #000; border-top:none; border-collapse:collapse;\">\n        <tr style=\"background-color: #f0f0f0;\">\n            <td style=\"padding: 5px; width: 33%;text-align:center; border-right:1px solid #000;\"><strong>Supplier</strong></td>\n            <td style=\"padding: 5px; width: 33%;text-align:center; border-right:1px solid #000;\"><strong>Ship to Address</strong></td>\n            <td style=\"padding: 5px; width: 34%;text-align:center;\"><strong>Bill to Address</strong></td>\n        </tr>\n        <tr>\n            <td style=\"padding: 8px; vertical-align: top; border-right:1px solid #000;\">\n                <b>{{doc.supplier or ''}}</b>\n                <br>\n                {{doc.address_display or ''}}\n            </td>\n            <td style=\"padding: 8px; vertical-align: top; border-right:1px solid #000;\">\n                {%if doc.shipping_address  %}\n                <b>{{frappe.db.get_value('Address',doc.shipping_address,\"address_title\")}}</b> \n      \n                <br>\n                {{doc.shipping_address_display or ''}}\n                {%endif%}\n            </td>\n            <td style=\"padding: 8px; vertical-align: top;\">\n                  {%if doc.billing_address  %}\n                <b>{{frappe.db.get_value('Address',doc.billing_address,\"address_title\")}}</b> \n      \n                <br>\n                {{doc.billing_address_display or ''}}\n                {%endif%}\n            </td>\n        </tr>\n    </table>\n   \n    <!-- ITEMS TABLE -->\n    <table width='100%' class=\"mt\">\n        <thead>\n            <tr>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:5%;\">Sr.No.</td>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:37.3%;\">Description Of Goods</td>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:10%;\">HSN/SAC Code</td>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:7%;\">Qty</td>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:7%;\">UOM</td>\n                <td style=\"background-color:#D3D3D3;text-align:right;width:7%\">Required\nBy Date</td>\n                \n                <td style=\"background-color:#D3D3D3;text-align:center;width:7%;\">Rate</td>\n                <td style=\"background-color:#D3D3D3;text-align:center;width:12%;border-right:1px solid black\">Amount</td>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td style=\"text-align:center\">{{ loop.index }}</td>\n                <td><b>{{ item.item_name}}</b><br>{{item.description or ''}}</td>\n                <td style=\"text-align:center;\">{{ item.gst_hsn_code or ''}}</td>\n                <td style=\"text-align:center;\">{{ item.qty or '0'}}</td>\n                <td style=\"text-align:center;\">{{ item.uom}}</td>\n                <td style=\"text-align:center;white-space:nowrap\">\n  {%set date = item.get_formatted(\"schedule_date\") %}\n                     {{ frappe.utils.formatdate(date, \"dd-MM-yyyy\") }}\n</td>\n                <td style=\"text-align:right;white-space:nowrap\">{{item.get_formatted(\"rate\") or ''}}</td>\n                \n                <td style=\"text-align:right;white-space:nowrap;border-right:1px solid black\">{{ item.get_formatted(\"amount\") }}</td>\n            </tr>\n            {% endfor %}\n        \n            {% set total = doc.items|length %}\n            {% if total < 7%}\n                {% for i in range(7- total) %}\n            <tr class=\"filler-row\">\n  <td>&nbsp;</td>\n  <td></td>\n  <td></td>\n  <td></td>\n  <td></td>\n  <td></td>\n  <td></td>\n  <td style=\"border-right:1px solid black\"></td>\n</tr>    {% endfor %}\n            {% endif %}\n            \n            <tr style=\"border-top:1px solid black;\">\n                <td style=\"border-top:1px solid black;\"></td>\n                <td style=\"text-align:right;border-top:1px solid black;\"><b>Total</b></td>\n                <td style=\"border-top:1px solid black;\"></td>\n                <td style=\"text-align:center;border-top:1px solid black;\"><b>{{ doc.items|sum(attribute='qty') }}</b></td>\n                <td style=\"border-top:1px solid black;\"></td>\n\n                <td style=\"border-top:1px solid black;\"></td>\n                <td style=\"border-top:1px solid black;\"></td>\n                <td style=\"text-align:right;white-space:nowrap;border-top:1px solid black;border-right:1px solid black;\"><b></b></td>\n            </tr>\n        </tbody>\n    </table>\n    \n    <!-- SUMMARY SECTION -->\n    <div style=\"width:100%; border:1px solid #000; border-top:none; font-size:10px; display:table; border-collapse:collapse;\">\n        <!-- LEFT SIDE -->\n        <div style=\"display:table-cell; width:50%; border-right:1px solid #000; vertical-align:top;\">\n            <div style=\"padding:5px; border-bottom:1px solid #000;\">\n                Amount Chargeable (in words) :<br>\n                <b>{{ doc.in_words }}</b>\n            </div>\n            <div style=\"padding:6px;\">\n                <div style=\"display:table; width:100%;\">\n                    <div style=\"display:table-cell; width:25%; vertical-align:top;\">\n                        <b>Bank Details:</b>\n                    </div>\n                    <div style=\"display:table-cell; vertical-align:top;\">\n                        {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1,\"company\":doc.company},\"name\") %}\n                        {% if bank %}\n                            {% set bank_add = frappe.get_doc(\"Bank Account\", bank) %}\n                            {{ bank_add.bank }}<br>\n                            A/C No: {{ bank_add.bank_account_no or '' }}<br>\n                            IFSC: {{ bank_add.custom_ifsc or '' }}<br>\n                            SWIFT: {{ frappe.db.get_value(\"Bank\", bank_add.bank, \"swift_number\") or '' }}\n                        {% endif %}\n                    </div>\n                </div>\n            </div>\n        </div>\n    \n        <!-- RIGHT SIDE -->\n        <div style=\"display:table-cell; width:50%; vertical-align:top;\">\n            <div style=\"display:table; width:100%; border-collapse:collapse;\" class=\"main\">\n                <div style=\"display:table-row;\">\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                        <b>Taxable Amount :</b>\n                    </div>\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;border-left:1px solid #000; white-space:nowrap;\">\n                        <b>{{ doc.get_formatted(\"total\") }}</b>\n                    </div>\n                </div>\n                {% if doc.taxes and doc.taxes|length > 0 %}\n                    {% for row in doc.taxes %}\n                    <div style=\"display:table-row;\">\n                        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                            <b>{{ row.description }} @ {{row.rate}}% :</b>\n                        </div>\n                        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000;white-space:nowrap;\">\n                            <b>{{ row.get_formatted(\"tax_amount\") }}</b>\n                        </div>\n                    </div>\n                    {% endfor %}\n                {% endif %}\n                <div style=\"display:table-row;\">\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                        <b>Round off :</b>\n                    </div>\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000;white-space:nowrap;\">\n                        <b>{{ doc.get_formatted(\"rounding_adjustment\") or \"0.00\" }}</b>\n                    </div>\n                </div>\n              {%if doc.additional_discount_percentage or doc.discount_amount %}\n          <div style=\"display:table-row;\">\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right;\">\n              <b>Total Amount After Tax:</b>\n            </div>\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right; white-space:nowrap;border-left:1px solid #000;\">\n              <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n            </div>\n          </div>\n          {%else%}\n             <div style=\"display:table-row;\">\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right;border-bottom:1px solid black;\">\n              <b>Total Amount After Tax:</b>\n            </div>\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right; white-space:nowrap;border-left:1px solid #000;border-bottom:1px solid black;border-left:1px solid black;\">\n              <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n            </div>\n          </div>\n       \n          {%endif%}\n        \n            </div>\n        </div>\n    </div>\n    \n    <!-- TAX WORDS -->\n    <table style=\"width:100%; border:1px solid #000; border-top:none;\">\n        <tr>\n            <td width=50% style=\"border-bottom:none; padding:5px;\">\n                Tax Amount (in words) :<br>\n                <b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\n            </td>\n            <td width=50% style=\"text-align:center; padding:10px; border-left:1px solid #000;\">\n                <b>Certified that the particulars given above are true</b>\n            </td>\n        </tr>\n    </table>\n    \n    <!-- TERMS & SIGNATURE WITH QR CODE -->\n  \n <table style=\"width:100%; table-layout:fixed;\">\n  <tr>\n\n<td style=\"\n  width:50%;\n  text-align:left;\n  vertical-align:top;\n  padding:5px;\n\n  white-space:normal;\n  word-wrap:break-word;\n  word-break:break-word;\n  overflow-wrap:break-word;\n    word-break: break-all;\n  overflow:visible;\n\">\n  <strong>Terms &amp; Conditions :</strong><br>\n  {{ doc.terms or ''}}\n</td>\n    <!-- QR Code -->\n\n    <!-- Signature -->\n    <td style=\"width:30%; text-align:center; vertical-align:top; padding:5px;\">\n      <b>For, <strong>{{doc.company}}</strong></b>\n      <br><br><br><br><br><br><br><br><br><br><br>\n      Authorised Signatory\n    </td>\n\n  </tr>\n</table>   </div>\n    \n    </body>\n</html>",
