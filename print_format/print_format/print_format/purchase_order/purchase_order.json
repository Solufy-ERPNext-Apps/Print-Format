 "doctype": "Print Format",
 "font_size": 14,
 "html": "<html>\n    <head>\n<style>\n.print-format .test {\n    padding: 0px !important;\n    border: none !important;\n}\n@page {\n    size: A4;\n    margin: 8mm 5mm;\n}\n\nbody {\n    margin: 0;\n    padding: 0;\n    font-family: Arial, sans-serif;\n    font-size: 11px;\n}\n\n/* TABLE BASE */\ntable {\n    border:1px solid black;\n    width: 100%;\n    border-collapse: collapse;\n}\n\n.table1 tr td:nth-child(4){ \n    border-left:1px solid black;\n}\n/* BORDER UTIL */\n.border {\n    border: 1px solid #000;\n}\n\n.no-border {\n    border: none !important;\n}\n\n/* TEXT ALIGN */\n.text-center { text-align: center; }\n.text-right { text-align: right; }\n.nowrap { white-space: nowrap; }\n\n/* ITEM TABLE */\n.item-table th,\n.item-table td {\n    border: 1px solid #000;\n    padding: 4px;\n    font-size: 10px;\n}\n\n.item-table th {\n    background-color: #D3D3D3;\n    text-align: center;\n}\n\n/* COLUMN WIDTHS */\n.small-col { width: 7%; }\n.desc-col { width: 35%; }\n.hsn-col { width: 10%; }\n.amount-col { width: 12%; }\n\n/* FIX ROW HEIGHT */\n.filler-row td {\n    height: 22px;\n}\n\n/* PREVENT PAGE BREAK */\ntr {\n    page-break-inside: avoid;\n}\n\n/* SUMMARY TABLE */\n.summary-table td {\n    padding: 6px 10px;\n}\n\n.summary-table td:first-child {\n    border-bottom: 1px solid #000;\n}\n\n.summary-table td:last-child {\n    border-bottom: 1px solid #000;\n    border-left: 1px solid #000;\n}\n\n</style>    </head>\n    <body>\n    \n    <div class='fit-to-page page-break'>\n    \n    {% set currency_symbol = frappe.db.get_value(\"Currency\", doc.currency, \"symbol\") %}\n    \n    <div class=tab-cont>\n      <div>\n        {% if letter_head %}\n        {{ letter_head }}\n        {% else %}\n        {% endif %}\n      </div>\n    </div>\n    \n    <!-- TITLE -->\n    <table style='border-bottom:none'>\n        <tr >\n            <td ><b><center>Purchase Order</center></b></td>\n        </tr>\n    </table>\n    \n    <!-- ADDRESSES -->\n    \n    <!-- PO DETAILS -->\n    <table style=\"width:100%; border-collapse:collapse;line-height:0.3\" class=\"table1\" >\n\n    <tr>\n        <!-- LEFT SIDE (50%) -->\n        <td style=\"width:20%;\" class=\"bn\"><strong>PO No.</strong></td>\n        <td style=\"width:5%;\" class=\"bn\">:</td>\n        <td style=\"width:25%;\" class=\"bn\"><b>{{ doc.name or \"\" }}</b></td>\n\n        <!-- RIGHT SIDE (50%) -->\n        <td style=\"width:25%;\" class=\"bn\"><strong>Mode of Dispatch</strong></td>\n        <td style=\"width:5%;\" class=\"bn\">:</td>\n        <td style=\"width:20%;\" class=\"bn\">{{ doc.custom_mode_of_dispatch or '' }}</td>\n    </tr>\n\n    <tr>\n        <td class=\"bn\"><strong>PO Date</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">\n            {{ frappe.format_date(doc.transaction_date, \"dd-MM-yyyy\") if doc.transaction_date else \"\" }}\n        </td>\n\n        <td class=\"bn\"><strong>Payment Terms</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">{{ doc.payment_terms_template or \"\" }}</td>\n    </tr>\n\n    <tr>\n        <td class=\"bn\"><strong>Quote Ref.</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">{{ doc.items[0].supplier_quotation or \"\" }}</td>\n\n        <td class=\"bn\"><strong>Delivery Terms</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">{{ doc.custom_delivery_terms or '' }}</td>\n    </tr>\n\n    <tr>\n        <td class=\"bn\"><strong>Quote Date</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">\n            {% set quote = doc.items[0].supplier_quotation %}\n            {% if quote %}\n                {% set quote_date = frappe.db.get_value(\"Supplier Quotation\", quote, \"transaction_date\") %}\n                {% if quote_date %}\n                    {{ frappe.utils.formatdate(quote_date, \"dd-MM-yyyy\") }}\n                {% endif %}\n            {% endif %}\n        </td>\n\n        <td class=\"bn\"><strong>Warranty Terms</strong></td>\n        <td class=\"bn\">:</td>\n        <td class=\"bn\">{{ doc.custom_warranty_terms or '' }}</td>\n    </tr>\n\n</table>\n<table style=\"width:100%; border:1px solid #000; border-top:none; border-collapse:collapse;\">\n        <tr style=\"background-color: #f0f0f0;\">\n            <td style=\" width: 33%;text-align:center; border-right:1px solid #000;\"><strong>Supplier</strong></td>\n            <td style=\" width: 33%;text-align:center; border-right:1px solid #000;\"><strong>Ship to Address</strong></td>\n            <td style=\" width: 34%;text-align:center;\"><strong>Bill to Address</strong></td>\n        </tr>\n        <tr>\n            <td style=\"padding: 8px; vertical-align: top; border-right:1px solid #000;\">\n                <b>{{doc.supplier or ''}}</b>\n                <br>\n                {{doc.address_display or ''}}\n            </td>\n            <td style=\"padding: 8px; vertical-align: top; border-right:1px solid #000;\">\n                {%if doc.shipping_address  %}\n                <b>{{frappe.db.get_value('Address',doc.shipping_address,\"address_title\")}}</b> \n      \n                <br>\n                {{doc.shipping_address_display or ''}}\n                {%endif%}\n            </td>\n            <td style=\"padding: 8px; vertical-align: top;\">\n                  {%if doc.billing_address  %}\n                <b>{{frappe.db.get_value('Address',doc.billing_address,\"address_title\")}}</b> \n      \n                <br>\n                {{doc.billing_address_display or ''}}\n                {%endif%}\n            </td>\n        </tr>\n    </table>\n   \n    <!-- ITEMS TABLE --><table  border=1>\n\n    <!-- HEADER -->\n    <tr>\n        <th style=\"width:5%;\">Sr.No.</th>\n        <th style=\"width:35%;\">Description Of Goods</th>\n        <th style=\"width:10%;\">HSN/SAC</th>\n        <th style=\"width:7%;\">Qty</th>\n        <th style=\"width:7%;\">UOM</th>\n        <th style=\"width:10%;\">Req. Date</th>\n        <th style=\"width:10%;\">Rate</th>\n        <th style=\"width:16%;\">Amount</th>\n    </tr>\n\n    <!-- ITEMS -->\n    {% for item in doc.items %}\n    <tr>\n        <td class=\"text-center\">{{ loop.index }}</td>\n\n        <td>\n            <b>{{ item.item_name }}</b><br>\n            {{ item.description or '' }}\n        </td>\n\n        <td class=\"text-center\">{{ item.gst_hsn_code or '' }}</td>\n        <td class=\"text-center\">{{ item.qty or '0' }}</td>\n        <td class=\"text-center\">{{ item.uom }}</td>\n\n        <td class=\"text-center\" style='white-space:nowrap'>\n            {% set date = item.get_formatted(\"schedule_date\") %}\n            {{ frappe.utils.formatdate(date, \"dd-MM-yyyy\") }}\n        </td>\n\n        <td class=\"text-right\" style='white-space:nowrap'>\n            {{ item.get_formatted(\"rate\") }}\n        </td>\n\n        <td class=\"text-right\" >\n            {{ item.get_formatted(\"amount\") }}\n        </td>\n    </tr>\n    {% endfor %}\n\n    <!-- TOTAL ROW -->\n    <tr>\n        <td></td>\n        <td class=\"text-right\"><b>Total</b></td>\n        <td></td>\n\n        <td class=\"text-center\">\n            <b>{{ doc.items|sum(attribute='qty') }}</b>\n        </td>\n\n        <td></td>\n        <td></td>\n        <td></td>\n\n        <td class=\"text-right\">\n            <b>{{ doc.get_formatted(\"total\") }}</b>\n        </td>\n    </tr>\n\n    <tr>\n\n        <td colspan=\"4\" style=\"vertical-align:top; border-top:1px solid #000;\">\n\n            <b>Amount Chargeable (in words) :</b><br>\n            {{ doc.in_words }}\n\n            <br><br>\n\n            <b>Bank Details:</b><br>\n            {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1,\"company\":doc.company},\"name\") %}\n            {% if bank %}\n                {% set bank_add = frappe.get_doc(\"Bank Account\", bank) %}\n                {{ bank_add.bank }}<br>\n                A/C No: {{ bank_add.bank_account_no or '' }}<br>\n                IFSC: {{ bank_add.custom_ifsc or '' }}<br>\n                SWIFT: {{ frappe.db.get_value(\"Bank\", bank_add.bank, \"swift_number\") or '' }}\n            {% endif %}\n\n        </td>\n        <td colspan=\"4\" style=\"vertical-align:top; border-top:1px solid #000; padding:0;\" class='test'>\n\n     \n            <table style=\"width:100%; border-collapse:collapse;\" border=1>\n                <tr>\n                    <td style=\"text-align:right;\">Taxable Amount :</td>\n                    <td style=\"text-align:right; border-left:1px solid #000;\">\n                        {{ doc.get_formatted(\"total\") }}\n                    </td>\n                </tr>\n\n                {% for row in doc.taxes %}\n                <tr>\n                    <td style=\"text-align:right;\">\n                        {{ row.description }} @ {{ row.rate }}%\n                    </td>\n                    <td style=\"text-align:right; border-left:1px solid #000;\">\n                        {{ row.get_formatted(\"tax_amount\") }}\n                    </td>\n                </tr>\n                {% endfor %}\n\n                <tr>\n                    <td style=\"text-align:right;\">Round off :</td>\n                    <td style=\"text-align:right; border-left:1px solid #000;\">\n                        {{ doc.get_formatted(\"rounding_adjustment\") }}\n                    </td>\n                </tr>\n\n                <tr>\n                    <td style=\"text-align:right;\"><b>Total :</b></td>\n                    <td style=\"text-align:right; border-left:1px solid #000;\">\n                        <b>\n                            {{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}\n                        </b>\n                    </td>\n                </tr>\n            </table>\n\n        </td>\n\n    </tr>\n\n</table> \n    <table  border=1>\n        <tr>\n            <td width=50% >\n                Tax Amount (in words) :<br>\n                <b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\n            </td>\n            <td width=50% >\n                <b>Certified that the particulars given above are true</b>\n            </td>\n        </tr>\n    <tr>\n\n<td style=\"\n  width:50%;\n  text-align:left;\n  vertical-align:top;\n  padding:5px;\n\n  white-space:normal;\n  word-wrap:break-word;\n  word-break:break-word;\n  overflow-wrap:break-word;\n    word-break: break-all;\n  overflow:visible;\n\">\n  <strong>Terms &amp; Conditions :</strong><br>\n  {{ doc.terms or ''}}\n</td>\n    <!-- QR Code -->\n\n    <!-- Signature -->\n    <td style=\"width:30%; text-align:center; vertical-align:top; padding:5px;\">\n      <b>For, <strong>{{doc.company}}</strong></b>\n      <br><br><br><br><br><br><br><br><br><br><br>\n      Authorised Signatory\n    </td>\n\n  </tr>\n</table>   </div>\n    \n    </body>\n</html>",
