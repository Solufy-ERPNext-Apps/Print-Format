 "doctype": "Print Format",
 "font_size": 14,
 "html": "<html>\n<head>\n  <style>\n  .ql-editor.read-mode{\n      height: auto !important;\n  }\n  tr, td {\n    page-break-inside: avoid !important;\n    break-inside: avoid !important;\n  }\n    table {\n      border-collapse: collapse;\n      width: 100%;\n      font-size:13px;\n    }\n    .fit-to-page {\n      zoom: 0.80;\n      transform: scale(0.95);       /* shrink slightly */\n      transform-origin: top left;   /* shrink from top left */\n      width: 100%; /* slightly smaller to fit 1 page */\n    }\n    td {\n\n      padding: 6px;\n      color:black;\n    }\n    th {\n      padding: 6px;\n    }\n    .center {\n      text-align: center;\n      font-weight: bold;\n    }\n    \n\n  </style>\n</head>\n<body>\n    <div class=\"fit-to-page\">\n    {% if letter_head %}\n       {{ letter_head }}\n    {% endif %}\n  <table border=\"1\" style=\"width:100%;\">\n  <tr>\n    <td colspan=\"4\" class=\"center\"\n        style=\"height:30px;font-size:18px; background-color:#a6a6a6;\">\n      Proforma Invoice\n    </td>\n  </tr>\n\n  <tr>\n    <td colspan=\"2\"\n        rowspan=\"4\"\n        style=\"font-size:13px;height:120px;width:50%; border-right:1px solid black;\">\n      <b>To:</b> {{ doc.customer_name }}<br>\n      {% if doc.customer_address %}\n        Address: {{ doc.address_display }}<br>\n      {% endif %}\n      {% if doc.contact_mobile %}\n        Phone: {{ doc.contact_mobile }}\n      {% endif %}\n    </td>\n\n    <td colspan=\"2\"\n        rowspan=\"4\"\n        style=\"font-size:13px;height:120px;width:50%;\">\n      <b>Shipping Address:</b><br>\n      {{ doc.shipping_address or \"\" }}\n    </td>\n  </tr>\n\n  <tr></tr>\n  <tr></tr>\n  <tr></tr>\n</table>\n<table border=\"1\">\n    <tr>\n        <td style=\"width: 33.3%;border-right:none;\"><b>Proforma Invoice No:</b> {{ doc.name }}</td>\n        <td style=\"width: 33.3%;\"><b>Delivery Date:</b>\n          {{ frappe.utils.get_datetime(doc.transaction_date).strftime(\"%d-%m-%Y\") }}\n        </td>\n        <!--<td style=\"border-left:none;\"><b>Terms:</b> {{ doc.payment_terms_template or \"\" }}</td>-->\n    </tr>\n    <tr>\n        <td style=\"border-right:none;\"><b>Customer PO No:</b> {{ doc.po_no }}</td>\n        <td style=\"\"><b>Customer PO Date:</b>\n          {{ frappe.utils.get_datetime(doc.po_date).strftime(\"%d-%m-%Y\") }}\n        </td>\n        <!--<td style=\"border-left:none;\"><b>Terms:</b> {{ doc.payment_terms_template or \"\" }}</td>-->\n    </tr>\n    <tr>\n       <!--<td style=\"border-right:none;\"><b>RFQ #:</b> {{ doc.custom_rfq or \"\" }}</td>-->\n        <td colspan = 2 style=\"border-right:1px solid black; \"><b>Terms:</b> {{ doc.payment_terms_template or \"\" }}</td>\n    </tr>\n    <tr>\n  </tr>\n    </table>\n\n  <table border=\"1\" style = \"page-break-inside: unset;\">\n  <tr >\n        <th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>Sr</b></th>\n        <th colspan=\"2\" style=\"background-color:#a6a6a6;text-align:center;color:black;\">\n            <b>Part Number/Description</b>\n        </th>\n        <th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>CD</b></th>\n        <th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>Qty</b></th>\n        <!--<th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>Lead Time</b></th>-->\n        <!--<th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>List Price</b></th>-->\n        <th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>Unit Price</b></th>\n        <th style=\"background-color:#a6a6a6;text-align:center;color:black;\"><b>Amount</b></th>\n    </tr>\n\n  {% for i in doc.items %}\n  <tr style = \"page-break-inside: unset;\">\n    <td class=\"center\">{{ i.idx }}</td>\n     <td colspan=\"2\" style=\"font-size:x-small; page-break-inside:unset;\">\n      {{ i.item_code }}<br>\n     <p style = \"page-break-inside:unset;\">{{i.item_name }}<br>{{ i.custom_remarks.replace('\\n', '<br>') if i.custom_remarks else '' }}</p>\n   </td>\n    <td class=\"center\">{{ i.custom_condition }}</td>\n    <td class=\"center\">{{ i.get_formatted(\"qty\") }}</td>\n    <!--<td style=\"text-align:center;\">{{ i.custom_lead_time or \"\" }}</td>-->\n    <td style=\"text-align:right;\">{{ \"${:,.2f}\".format(i.rate) }}</td>\n    <td style=\"text-align:right;\">{{ \"${:,.2f}\".format(i.amount) }}</td>\n  </tr>\n  {% endfor %}\n\n  <tr>\n    <td colspan=\"5\" rowspan=\"{{ 5 if doc.discount_amount and doc.discount_amount != 0 else 4 }}\">\n      <b>Terms and Conditions:</b><br>\n      {{ doc.terms or \"\" }}\n    </td>\n    <td><b>Item Total:</b></td>\n    <td colspan=\"3\" style=\"text-align:center;\">{{ doc.get_formatted(\"total_qty\") }}</td>\n  </tr>\n\n  {% if doc.discount_amount and doc.discount_amount != 0 %}\n  <tr>\n    <td><b>Discount:</b></td>\n    <td style=\"text-align:right;\">{{ doc.get_formatted(\"discount_amount\") }}</td>\n  </tr>\n  {% endif %}\n  {% set symbol = frappe.get_doc(\"Currency\", doc.currency).symbol %}\n  <tr>\n    <td><b>Sub Total:</b></td>\n    <td colspan=\"3\" style=\"text-align:right;\">{{ symbol }} {{ doc.get_formatted(\"net_total\").replace(symbol, \"\").strip() }}</td>\n  </tr>\n\n  <tr>\n    <td><b>Total:</b></td>\n    <td colspan=\"3\" style=\"text-align:right;\">{{symbol }} {{ doc.get_formatted(\"grand_total\").replace(symbol, \"\").strip() }}</td>\n  </tr>\n\n  <tr>\n    <td colspan=\"4\" class=\"left\">\n      <b>Payable in {{ doc.currency }}</b>\n    </td>\n  </tr>\n</table>\n<table border=1>\n    <tr>\n        <td>\n            Payment Term\n        </td>\n        <td>\n            Due Date\n        </td>\n        <td>\n            Invoice Portion\n        </td>\n        <td>\n            Payment Amount\n        </td>\n    </tr>\n    {%for i in doc.payment_schedule%}\n    <tr>\n        <td>\n            {{i.payment_term}}\n        </td>\n        <td>\n            {{i.due_date}}\n        </td>\n        <td>\n            {{i.get_formatted('invoice_portion')}}\n        </td>\n        <td>\n            {{i.get_formatted(\"payment_amount\")}}\n        </td>\n    </tr>\n    \n    {%endfor%}\n</table>\n\n</div>\n</body>\n</html>",
