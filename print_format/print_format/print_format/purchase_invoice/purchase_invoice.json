 "doc_type": "Purchase Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\ntable {\n        margin-left: auto;\n        margin-right: auto;\n        width: 100%;\n        font-size: 10px;\n        border: 1px solid black;\n        border-collapse: collapse;\n    }\n    td {\n        border: 1px solid black;\n        text-align: left;\n        font-size: 10px;\n    }\n    h1 {\n        color: black;\n    }\n    img {\n        width: 95px;\n        height: 95px;\n    }\n.print-format .letter-head {\n    margin-bottom: -1px;\n}\n/* COMMON */\n.signature{\n     border-top:none !important;\n}\n\n\n.letter-head table tr:first-child th,\n.letter-head table tr:first-child td {\n    border-top: 1px solid #000 !important;\n}\n\n .item-row td { border-top:1px solid black!important; }\n    .wrap{\n        white-space:nowrap;\n    }\n\n .wrap{\n        white-space:nowrap;\n    }\n    .total-row { font-weight: bold; }\n  \n  * {\n    font-size: 11px;\n    font-family: Arial, sans-serif;\n  }\n  thead tr th { text-align: center; }\n  .center { text-align: center; }\n  .right  { text-align: right; }\n  .items-header {\n    background-color: #f0f0f0;\n    font-weight: bold;\n    font-size: 9pt;\n    padding: 5px;\n  }\n  .item-row td { padding: 5px; }\n  \ntable {\n    width: 100%;\n    border-collapse: collapse;\n}\n\n/* INFO TABLE */\n.info-table td {\n    padding: 5px 8px;\n    /*font-weight: bold;*/\n    border: none;\n    line-height:0.3;\n}\n.info-table tr td:nth-of-type(1),\n.info-table tr td:nth-of-type(3) {\n    font-weight: bold;\n}\n/* LAST ROW TOP BORDER */\n.info-table tr:last-child td {\n    border-top: 1px solid #000;\n}\n\n/* MIDDLE LINE */\n.info-table td:nth-child(3) {\n    border-left: 1px solid #000;\n}\n\n/* ITEMS */\n\n\n.item-row td {\n    padding: 5px;\n}\n\n/* PAGE */\n@page {\n    size: A4;\n    margin: 8mm 5mm;\n}\n\nbody {\n    font-family: Arial;\n    font-size: 8px;\n}\n\n</style>\n\n<div>\n\n  <div class=\"letter-head\">\n        {% if letter_head %}\n            {{ letter_head }}\n           {% endif %}\n    </div>\n<!-- TITLE -->\n<table border=1>\n<tr>\n<td class=\"center\" style=\"font-size:14px; font-weight:bold;\">\nPURCHASE INVOICE\n</td>\n</tr>\n</table>\n\n<!-- HEADER (FIXED STRUCTURE ONLY) -->\n<table border=\"1\">\n\n<tr>\n\n<td style=\"padding:5px 8px;\">\n<b>Invoice To</b><br>\n<strong>{{ doc.company }}</strong><br>\n{{ doc.shipping_address_display or \"\" }}\n</td>\n\n<td style=\"padding:5px 8px;\">\n<b>Despatch To</b><br>\n<strong>{{ doc.company }}</strong><br>\n{{ doc.shipping_address_display or \"\" }}\n</td>\n\n<td style=\"padding:5px 8px;\">\n<b>Supplier</b><br>\n<strong>{{ doc.supplier }}</strong><br>\n{{ doc.supplier_address_display or \"\" }}\n</td>\n\n</tr>\n\n</table>\n\n<table class=\"info-table\" border=\"1\" >\n\n<tr>\n<td style=\"font-weight:bold;\">Voucher No:</td>\n<td>{{ doc.name }}</td>\n\n<td>Date:</td>\n<td>{{ frappe.utils.formatdate(doc.transaction_date) }}</td>\n</tr>\n\n<tr>\n<td>Payment Terms:</td>\n<td>{{ doc.payment_terms_template or \"\" }}</td>\n\n\n<td>Terms of Delivery:</td>\n<td colspan=\"\">{{ doc.incoterm or \"\" }}</td>\n</tr>\n\n<tr>\n<td>Supplier Ref:</td>\n<td>{{ doc.supplier_delivery_note or \"\" }}</td>\n\n<td>Other Ref:</td>\n<td>{{ doc.remarks or \"\" }}</td>\n</tr>\n\n<tr>\n<td>Transport:</td>\n<td>{{ doc.transporter_name or \"\" }}</td>\n\n<td>Destination:</td>\n<td>{{ doc.shipping_address_name or \"\" }}</td>\n</tr>\n\n<tr>\n</tr>\n\n</table>\n\n<!-- ITEMS TABLE -->\n<style>\n  table {\n    border-collapse: collapse;\n    width: 100%;\n    table-layout: fixed;\n  }\n  th, td {\n    border: 1px solid #000;\n    padding: 4px;\n    font-size: 11px;\n    word-wrap: break-word;\n  }\n  .center { text-align: center; }\n  .right { text-align: right; }\n  .wrap { white-space: normal; }\n  .items-header { font-weight: bold; }\n</style>\n{% set tax_ns = namespace(labels=[], rates={}, amounts={}) %}\n\n{% for tax in doc.taxes %}\n  \n  {% set label = tax.description or tax.account_head %}\n\n  {# Add label only once #}\n  {% if label not in tax_ns.labels %}\n    {% set _ = tax_ns.labels.append(label) %}\n  {% endif %}\n\n  {# Store rate #}\n  {% set _ = tax_ns.rates.update({label: tax.rate or 0}) %}\n\n  {# Store total tax amount #}\n  {% set _ = tax_ns.amounts.update({label: tax.tax_amount or 0}) %}\n\n{% endfor %}\n<table border=\"1\" width=\"100%\">\n\n  {# \u2500\u2500 COLUMN COUNT \u2500\u2500 #}\n  {% set base_columns = 5 %}\n  {% set tax_columns = tax_ns.labels | length %}\n  {% set total_columns = base_columns + tax_columns + 1 %}\n\n  <thead>\n    <tr>\n      <th class=\"items-header\" style=\"width:10%;\">Sl No.</th>\n      <th class=\"items-header\" style=\"width:30%;\">Description</th>\n      <th class=\"items-header\">HSN</th>\n      <th class=\"items-header center\">Qty</th>\n      <th class=\"items-header center\">Rate</th>\n\n      \n      {% for label in tax_ns.labels %}\n        <th class=\"items-header center\">{{ label }}</th>\n      {% endfor %}\n\n      <th class=\"items-header center\" style=\"width:15%;\">Amount</th>\n    </tr>\n  </thead>\n\n  <tbody>\n    {% for item in doc.items %}\n\n    {% set taxable = item.net_amount if item.net_amount is not none else (item.amount or 0) %}\n    {% set row_ns = namespace(total_tax=0, item_amounts={}) %}\n\n    {# \ud83d\udd25 Dynamic tax calc #}\n    {% for label in tax_ns.labels %}\n      {% set rate = tax_ns.rates.get(label, 0) %}\n      {% set amt = taxable * rate / 100 %}\n      {% set _ = row_ns.item_amounts.update({label: amt}) %}\n      {% set row_ns.total_tax = row_ns.total_tax + amt %}\n    {% endfor %}\n\n    {% set final_amt = taxable + row_ns.total_tax %}\n\n    <tr class=\"item-row\">\n      <td class=\"center\">{{ loop.index }}</td>\n\n      <td>\n        <b>{{ item.item_name }}</b><br>\n        <small>{{ item.description }}</small>\n      </td>\n\n      <td class=\"center\">{{ item.gst_hsn_code or \"\" }}</td>\n      <td class=\"center\">{{ item.qty }}</td>\n      <td class=\"right wrap\">{{ item.get_formatted(\"rate\") }}</td>\n\n      {# \ud83d\udd25 Dynamic tax columns #}\n      {% for label in tax_ns.labels %}\n        <td class=\"right wrap\">\n          {{ \"%.1f\"|format(tax_ns.rates.get(label, 0)) }}%<br>\n          {{ frappe.utils.fmt_money(row_ns.item_amounts.get(label, 0), currency=doc.currency) }}\n        </td>\n      {% endfor %}\n\n      <td class=\"right wrap\">\n        {{ frappe.utils.fmt_money(final_amt, currency=doc.currency) }}\n      </td>\n    </tr>\n\n    {% endfor %}\n  </tbody>\n\n  <tfoot>\n\n    {# \u2500\u2500 TOTAL ROW (DYNAMIC) \u2500\u2500 #}\n    <tr class=\"total-row item-row\">\n\n      <td colspan=\"3\" class=\"right\"><b>Total</b></td>\n\n      <td class=\"center wrap\">\n        {% set total_qty = namespace(value=0) %}\n        {% for item in doc.items %}\n          {% set total_qty.value = total_qty.value + item.qty %}\n        {% endfor %}\n        {{ total_qty.value | int }}\n      </td>\n\n      <td></td>\n\n      {# \ud83d\udd25 Dynamic Tax Totals #}\n      {% for label in tax_ns.labels %}\n        <td class=\"right wrap\">\n          {{ frappe.utils.fmt_money(tax_ns.amounts.get(label, 0), currency=doc.currency) }}\n        </td>\n      {% endfor %}\n\n      <td class=\"right wrap\">\n        {{ doc.get_formatted(\"grand_total\") }}\n      </td>\n    </tr>\n\n    {# \u2500\u2500 GRAND TOTAL ROW \u2500\u2500 #}\n \n  </tfoot>\n\n</table>    \n    <!-- SUMMARY SECTION -->\n    <div style=\"width:100%; border:1px solid #000; border-top:none; font-size:10px; display:table; border-collapse:collapse;\">\n        <!-- LEFT SIDE -->\n        <div style=\"display:table-cell; width:50%; border-right:1px solid #000; vertical-align:top;\">\n            <div style=\"padding:5px; border-bottom:1px solid #000;\">\n                Amount Chargeable (in words) :<br>\n                <b>{{ doc.in_words }}</b>\n            </div>\n            <div style=\"padding:6px;\">\n                <div style=\"display:table; width:100%;\">\n                    <div style=\"display:table-cell; width:25%; vertical-align:top;\">\n                        <b>Bank Details:</b>\n                    </div>\n                    <div style=\"display:table-cell; vertical-align:top;\">\n                        {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_company_account\":1,\"company\":doc.company},\"name\") %}\n                        {% if bank %}\n                            {% set bank_add = frappe.get_doc(\"Bank Account\", bank) %}\n                            {{ bank_add.bank }}<br>\n                            A/C No: {{ bank_add.bank_account_no or '' }}<br>\n                            IFSC: {{ bank_add.custom_ifsc or '' }}<br>\n                            SWIFT: {{ frappe.db.get_value(\"Bank\", bank_add.bank, \"swift_number\") or '' }}\n                        {% endif %}\n                    </div>\n                </div>\n            </div>\n        </div>\n    \n        <!-- RIGHT SIDE -->\n        <div style=\"display:table-cell; width:50%; vertical-align:top;\">\n            <div style=\"display:table; width:100%; border-collapse:collapse;\" class=\"main\">\n                <div style=\"display:table-row;\">\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                        <b>Taxable Amount :</b>\n                    </div>\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;border-left:1px solid #000; white-space:nowrap;\">\n                        <b>{{ doc.get_formatted(\"total\") }}</b>\n                    </div>\n                </div>\n                {% if doc.taxes and doc.taxes|length > 0 %}\n                    {% for row in doc.taxes %}\n                    <div style=\"display:table-row;\">\n                        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                            <b>{{ row.description }} @ {{row.rate}}% :</b>\n                        </div>\n                        <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000;white-space:nowrap;\">\n                            <b>{{ row.get_formatted(\"tax_amount\") }}</b>\n                        </div>\n                    </div>\n                    {% endfor %}\n                {% endif %}\n                <div style=\"display:table-row;\">\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000;\">\n                        <b>Round off :</b>\n                    </div>\n                    <div style=\"display:table-cell; padding:6px 10px; text-align:right; border-bottom:1px solid #000; border-left:1px solid #000;white-space:nowrap;\">\n                        <b>{{ doc.get_formatted(\"rounding_adjustment\") or \"0.00\" }}</b>\n                    </div>\n                </div>\n              {%if doc.additional_discount_percentage or doc.discount_amount %}\n          <div style=\"display:table-row;\">\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right;\">\n              <b>Total Amount After Tax:</b>\n            </div>\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right; white-space:nowrap;border-left:1px solid #000;\">\n              <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n            </div>\n          </div>\n          {%else%}\n             <div style=\"display:table-row;\">\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right;border-bottom:1px solid black;\">\n              <b>Total Amount After Tax:</b>\n            </div>\n            <div style=\"display:table-cell; padding:6px 10px; text-align:right; white-space:nowrap;border-left:1px solid #000;border-bottom:1px solid black;border-left:1px solid black;\">\n              <b>{{ doc.get_formatted(\"rounded_total\") if doc.rounded_total else doc.get_formatted(\"grand_total\") }}</b>\n            </div>\n          </div>\n       \n          {%endif%}\n        \n            </div>\n        </div>\n    </div>\n    \n    <!-- TAX WORDS -->\n    <table style=\"width:100%; border:1px solid #000; border-top:none;\">\n        <tr>\n            <td width=50% style=\"border-bottom:none; padding:5px;\">\n                Tax Amount (in words) :<br>\n                <b>{{ frappe.utils.money_in_words(doc.total_taxes_and_charges, doc.currency) }}</b>\n            </td>\n            <td width=50% style=\"text-align:center; padding:10px; border-left:1px solid #000;\">\n                <b>Certified that the particulars given above are true</b>\n            </td>\n        </tr>\n    </table>\n    \n    <!-- TERMS & SIGNATURE WITH QR CODE -->\n  \n <table style=\"width:100%; table-layout:fixed;\">\n  <tr>\n\n<td style=\"\n  width:50%;\n  text-align:left;\n  vertical-align:top;\n  padding:5px;\n\n  white-space:normal;\n  word-wrap:break-word;\n  word-break:break-word;\n  overflow-wrap:break-word;\n    word-break: break-all;\n  overflow:visible;\n\">\n  <strong>Terms &amp; Conditions :</strong><br>\n  {{ doc.terms or ''}}\n</td>\n    <!-- QR Code -->\n\n    <!-- Signature -->\n    <td style=\"width:30%; text-align:center; vertical-align:top; padding:5px;\">\n      <b>For, <strong>{{doc.company}}</strong></b>\n      <br><br><br><br><br><br><br><br><br><br><br>\n      Authorised Signatory\n    </td>\n\n  </tr>\n</table>   </div>\n    \n    </body>\n</html>\n",
