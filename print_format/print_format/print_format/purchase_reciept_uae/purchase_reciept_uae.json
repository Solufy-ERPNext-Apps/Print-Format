 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\ntable {\n        margin-left: auto;\n        margin-right: auto;\n        width: 100%;\n        font-size: 10px;\n        border: 1px solid black;\n        border-collapse: collapse;\n    }\n    td {\n        border: 1px solid black;\n        text-align: left;\n        font-size: 10px;\n    }\n    h1 {\n        color: black;\n    }  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { font-family: Arial, sans-serif; font-size: 11px; background: white; color: #000; -webkit-print-color-adjust: exact; }\n  .page { width: 100%; padding: 10px; }\n  table { border:1; width: 100%; }\n  .mb { border: 1px solid #000; }\n  .items-table th { background-color: #f0f0f0; text-align: center; font-size: 10px; padding: 4px; vertical-align: middle; font-weight: bold; }\n  .text-center { text-align: center; }\n  .text-right  { text-align: right; }\n  .bold        { font-weight: bold; }\n  .grand-total { font-size: 12px; font-weight: bold; background-color: #f0f0f0; }\n  .company-name { font-size: 14px; font-weight: bold; }\n  .bottom-note { text-align: center; font-size: 10px; border: 1px solid #000; border-top: none; padding: 4px; font-weight: bold; }\n  /* CHECK TABLE */\n  .check tr td { border: none; padding: 3px 6px; }\n  .check tr td:nth-child(3) { border-left: 1px solid #000; }\n  .check tr td:nth-child(3),\n  .check tr td:nth-child(1) { font-weight: bold; }\n  /* INFO TABLE */\n  .info-table { border: none; width: 100%; border-collapse: collapse; border-top: none; }\n  .info-table td { padding: 3px 6px; vertical-align: top; font-size: 10.5px; }\n  /* MAIN DIV \u2014 PDF safe display:table */\n  .main-div { display: table; width: 100%; border-collapse: collapse; border: 1px solid #000; border-top: none; }\n  .main-div-row { display: table-row; }\n  .left-div { display: table-cell; width: 40%; vertical-align: top; padding: 6px; border-right: 1px solid #000; }\n  .right-div { display: table-cell; width: 60%; vertical-align: top; padding: 0; }\n  .city td { border-bottom: 1px solid black; }\n</style>\n</head>\n<body>\n<div class=\"fit-to-page\">\n\n  <div>\n    {% if letter_head %}{{ letter_head }}{% endif %}\n  </div>\n\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"text-align:center; font-size:16px; font-weight:bold; padding:6px 10px;\">\n        {{ _(\"Purchase Receipt\") }}\n      </td>\n    </tr>\n  </table>\n\n  <div class=\"main-div\">\n    <div class=\"main-div-row\">\n\n      <div class=\"left-div\">\n        <div><b>{{ _(\"Supplier\") }} :</b></div>\n        <div>{{ doc.supplier_name }}</div>\n        {{ doc.address_display or \"\" }}\n        {% set sa = frappe.get_doc(\"Address\", doc.supplier_address) if doc.supplier_address else None %}\n        {% if sa %}\n          <div>{{ _(\"TRN\") }} : {{ sa.gstin or \"\" }}</div>\n        {% endif %}\n      </div>\n      <div class=\"right-div\">\n        <table class=\"info-table check\">\n          <tr>\n            <td>{{ _(\"Purchase Receipt No.:\") }}</td>\n            <td>{{ doc.name }}</td>\n            <td>{{ _(\"Dated:\") }}</td>\n            <td>{{ doc.get_formatted(\"posting_date\") }}</td>\n          </tr>\n          <tr>\n            <td>{{ _(\"Supplier:\") }}</td>\n            <td>{{ doc.supplier_name }}</td>\n            <td>{{ _(\"Supplier Delivery Note:\") }}</td>\n            <td>{{ doc.supplier_delivery_note or \"\" }}</td>\n          </tr>\n          <tr>\n            <td>{{ _(\"Supplier Invoice Date:\") }}</td>\n            <td>{{ doc.get_formatted(\"bill_date\") }}</td>\n            <td>{{ _(\"Payment Terms:\") }}</td>\n            <td>{{ doc.payment_terms_template or \"\" }}</td>\n          </tr>\n          <tr class=\"city\">\n            <td style=\"border-bottom:1px solid black;\"></td>\n            <td style=\"border-bottom:1px solid black;\"></td>\n            <td style=\"border-bottom:1px solid black;\"></td>\n            <td style=\"border-bottom:1px solid black;\"></td>\n          </tr>  <tr>\n            <td style='white-space:nowrap'>\n                <b>Terms Of Delievery:</b><br>\n                {{doc.incoterm or ''}}\n            </td>\n        </tr>\n        </table>\n      </div>\n\n    </div>\n  </div>\n\n <table class=\"items-table\" border=1>\n    <thead>\n      <tr>\n        <th style=\"width:28px;\">{{ _(\"Sr No.\") }}</th>\n        <th>{{ _(\"Description of Goods\") }}</th>\n        <th style=\"width:65px;\">{{ _(\"Quantity\") }}</th>\n        <th style=\"width:50px;\">{{ _(\"Rate\") }}</th>\n        <th style=\"width:35px;\">{{ _(\"Per\") }}</th>\n        <th style=\"width:40px;\">{{ _(\"VAT\") }} %</th>\n        <th style=\"width:70px;\">{{ _(\"Taxable Value\") }} {{doc.currency}}</th>\n        <th style=\"width:60px;\">{{ _(\"VAT Amount\") }} {{doc.currency}}</th>\n        <th style=\"width:75px;\">{{ _(\"Total Incl. VAT\") }} {{doc.currency}}</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set vat_rate = namespace(value=0) %}\n      {% for tax in doc.taxes %}\n        {% if tax.charge_type == \"On Net Total\" %}\n          {% set vat_rate.value = tax.rate %}\n        {% endif %}\n      {% endfor %}\n\n      {% for item in doc.items %}\n      <tr>\n        <td class=\"text-center\">{{ loop.index }}</td>\n        <td>\n          <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n        <td class=\"text-center\">{{ item.qty | int }} {{ item.uom }}</td>\n        <td class=\"\" style='white-space:nowrap' >{{item.get_formatted(\"rate\")}}</td>\n        <td class=\"text-center\">{{ item.uom }}</td>\n        <td class=\"text-center\">{{ vat_rate.value }}%</td>\n        <td class=\"text-right\">{{ item.get_formatted(\"amount\") }}</td>\n        <td class=\"text-right\">{{ frappe.utils.fmt_money(item.amount * vat_rate.value / 100, currency=doc.currency) }}</td>\n        <td class=\"text-right bold\">{{ frappe.utils.fmt_money(item.amount * (1 + vat_rate.value / 100), currency=doc.currency) }}</td>\n      </tr>\n      {% endfor %}\n\n    </tbody>\n    <tfoot>\n      <tr>\n        <td colspan=\"2\" class=\"text-right bold\">{{ _(\"Total\") }}</td>\n        <td class=\"text-center bold\">\n          {% set total_qty = namespace(value=0) %}\n          {% for item in doc.items %}{% set total_qty.value = total_qty.value + item.qty %}{% endfor %}\n          {{ total_qty.value | int }}\n        </td>\n        <td colspan=\"3\"></td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"total\") }}</td>\n        <td class=\"text-right bold\">\n          {% set vat = namespace(value=0) %}\n          {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n          {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n        </td>\n        <td class=\"text-right bold\">{{ doc.get_formatted(\"grand_total\") }}</td>\n      </tr>\n    </tfoot>\n  </table>\n\n  <!-- TOTALS BREAKDOWN -->\n  <table class=\"totals-table\">\n    <tr>\n      <td style=\"width:55%; vertical-align:top;\">\n        <b>{{ _(\"Amount Chargeable (in words)\") }}</b><br>\n        {{ doc.in_words or \"\" }}\n        <br>\n       <b> {{ _(\"VAT Amount Chargeable (in words)\") }}</b>\n        <br>\n        {{ frappe.utils.money_in_words(doc.total,doc.currency) }}\n      </td>\n      <td style=\"width:45%;\">\n        <table style=\"width:100%; border-collapse:collapse;\">\n          <tr>\n            <td>{{ _(\"Taxable Value\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"total\") }}</td>\n          </tr> \n          <tr>\n            <td>{{ _(\"Value Added Tax\") }} {{ vat_rate.value }}%</td>\n            <td class=\"text-right\">\n              {% set vat = namespace(value=0) %}\n              {% for tax in doc.taxes %}{% set vat.value = vat.value + tax.tax_amount %}{% endfor %}\n              {{ frappe.utils.fmt_money(vat.value, currency=doc.currency) }}\n            </td>\n          </tr>\n          {% if doc.discount_amount %}\n          <tr>\n            <td>{{ _(\"Discount\") }}</td>\n            <td class=\"text-right\">(-{{ doc.get_formatted(\"discount_amount\") }})</td>\n          </tr>\n          {% endif %}\n          {% if doc.rounding_adjustment %}\n          <tr>\n            <td>{{ _(\"Rounded Off\") }}</td>\n            <td class=\"text-right\">{{ doc.get_formatted(\"rounding_adjustment\") }}</td>\n          </tr>\n          {% endif %}\n          <tr class=\"grand-total\">\n            <td><b>{{ _(\"Invoice Total\") }}</b></td>\n            <td class=\"text-right bold\">\n              <b>\n                {% if doc.disable_rounded_total %}\n                  {{ doc.get_formatted(\"grand_total\") }}\n                {% else %}\n                  {{ doc.get_formatted(\"rounded_total\") or doc.get_formatted(\"grand_total\") }}\n                {% endif %}\n              </b>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n <div style=\"width:100%; display:table; border:1px solid #000; border-collapse:collapse;\">\n    <div style=\"display:table-row;\">\n\n      <div style=\"display:table-cell; width:55%; padding:5px; vertical-align:top; border-right:1px solid #000;\">\n        <strong>Terms &amp; Conditions:</strong><br>\n        <div style=\"white-space:pre-wrap;\">{{ doc.terms or \"\" }}</div>\n      </div>\n\n     \n      <div style=\"display:table-cell; width:25%; padding:5px; text-align:center; vertical-align:top;\">\n        <b>For, {{ doc.company }}</b>\n        <br><br><br><br>\n        Authorised Signatory\n      </div>\n\n    </div>\n  </div>\n\n  <!--<!-- BOTTOM NOTE -->\n  <div class=\"bottom-note\">\n    {{ _(\"This is a Computer Generated Invoice\") }}\n  </div>\n\n\n</div>\n</body>\n</html>",
