{
 "absolute_value": 0,
 "align_labels_right": 0,
 "country": "United Arab Emirates",
 "creation": "2026-03-19 14:36:30.690143",
 "css": "",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Sales Order",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body { font-family: Arial, sans-serif; font-size: 11px; background: white; color: #000; -webkit-print-color-adjust: exact; }\n  .page { width: 100%; padding: 10px; }\n  table { border-collapse: collapse; width: 100%; }\n  .mb { border: 1px solid #000; }\n  .mb td, .mb th { border: 1px solid #000; padding: 3px 6px; vertical-align: top; }\n  .lbl { width: 155px; }\n  .lbl .en { font-weight: bold; font-size: 10.5px; }\n  .lbl .ar { font-size: 10px; direction: rtl; text-align: right; color: #444; }\n  .items-table th { background-color: #f0f0f0; text-align: center; font-size: 10px; padding: 4px; vertical-align: middle; }\n  .items-table td { font-size: 10px; padding: 3px 4px; }\n  .text-center { text-align: center; }\n  .text-right  { text-align: right; }\n  .bold        { font-weight: bold; }\n  .grand-total { font-size: 12px; font-weight: bold; background-color: #f0f0f0; }\n  .ar { direction: rtl; text-align: right; }\n  .company-name { font-size: 14px; font-weight: bold; }\n  .sign-box { text-align: center; padding-top: 30px; font-size: 10px; }\n  .bottom-note { text-align: center; font-size: 10px; border: 1px solid #000; border-top: none; padding: 4px; }\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <!-- TITLE -->\n  <!-- CSV: Sales Order -> \u0637\u0644\u0628 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"text-align:center; font-size:16px; font-weight:bold; padding:6px 10px;\">\n        Sales Order / <span style=\"direction:rtl; font-size:15px;\">\u0637\u0644\u0628 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a</span>\n      </td>\n    </tr>\n  </table>\n\n  <!-- COMPANY INFO -->\n  <!-- CSV: Emirate -> \u0627\u0644\u0625\u0645\u0627\u0631\u0629 | Country -> \u0627\u0644\u062f\u0648\u0644\u0629 | TRN -> \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0636\u0631\u064a\u0628\u064a -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"padding:6px;\">\n        <div class=\"company-name\">{{ doc.company }}</div>\n        {% if doc.company_address %}\n          {% set ca = frappe.get_doc(\"Address\", doc.company_address) %}\n          <div>{{ ca.address_line1 or \"\" }}</div>\n          <div>{{ ca.city or \"\" }}</div>\n          <div>Emirate / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u0625\u0645\u0627\u0631\u0629</span> : {{ ca.state or \"\" }}</div>\n          <div>Country / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u062f\u0648\u0644\u0629</span> : {{ ca.country or \"\" }}</div>\n        {% endif %}\n        <div>TRN / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0636\u0631\u064a\u0628\u064a</span> : {{ doc.company_gstin or doc.tax_id or \"\" }}</div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- ORDER META -->\n  <!-- CSV:\n       Order No.                     -> \u0631\u0642\u0645 \u0627\u0644\u0637\u0644\u0628  (Sales Order -> \u0637\u0644\u0628 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a)\n       Dated                         -> \u0627\u0644\u062a\u0627\u0631\u064a\u062e\n       Customer                      -> \u0627\u0644\u0639\u0645\u064a\u0644\n       Customer's Purchase Order No. -> \u0631\u0642\u0645 \u0623\u0645\u0631 \u0634\u0631\u0627\u0621 \u0627\u0644\u0639\u0645\u064a\u0644  (Customer's Purchase Order -> \u0637\u0644\u0628 \u0634\u0631\u0627\u0621 \u0627\u0644\u0632\u0628\u0648\u0646)\n       Delivery Date                 -> \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0633\u0644\u064a\u0645\n       Payment Terms                 -> \u0634\u0631\u0648\u0637 \u0627\u0644\u062f\u0641\u0639   (Payment Terms -> \u0634\u0631\u0648\u0637 \u0627\u0644\u062f\u0641\u0639)\n       Sales Person                  -> \u0645\u0646\u062f\u0648\u0628 \u0645\u0628\u064a\u0639\u0627\u062a\n       Territory                     -> \u0625\u0642\u0644\u064a\u0645\n  -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td class=\"lbl\">\n        <div class=\"en\">Order No.</div>\n        <div class=\"ar\">\u0631\u0642\u0645 \u0627\u0644\u0637\u0644\u0628</div>\n      </td>\n      <td>{{ doc.name }}</td>\n      <td class=\"lbl\">\n        <div class=\"en\">Dated</div>\n        <div class=\"ar\">\u0627\u0644\u062a\u0627\u0631\u064a\u062e</div>\n      </td>\n      <td>{{ doc.transaction_date }}</td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">\n        <div class=\"en\">Customer</div>\n        <div class=\"ar\">\u0627\u0644\u0639\u0645\u064a\u0644</div>\n      </td>\n      <td>{{ doc.customer_name }}</td>\n      <td class=\"lbl\">\n        <div class=\"en\">Customer's Purchase Order No.</div>\n        <div class=\"ar\">\u0631\u0642\u0645 \u0623\u0645\u0631 \u0634\u0631\u0627\u0621 \u0627\u0644\u0639\u0645\u064a\u0644</div>\n      </td>\n      <td>{{ doc.po_no or \"\" }}</td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">\n        <div class=\"en\">Customer's Purchase Order Date</div>\n        <div class=\"ar\">\u062a\u0627\u0631\u064a\u062e \u0623\u0645\u0631 \u0634\u0631\u0627\u0621 \u0627\u0644\u0639\u0645\u064a\u0644</div>\n      </td>\n      <td>{{ doc.po_date or \"\" }}</td>\n      <td class=\"lbl\">\n        <div class=\"en\">Delivery Date</div>\n        <div class=\"ar\">\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0633\u0644\u064a\u0645</div>\n      </td>\n      <td>{{ doc.delivery_date or \"\" }}</td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">\n        <div class=\"en\">Payment Terms</div>\n        <div class=\"ar\">\u0634\u0631\u0648\u0637 \u0627\u0644\u062f\u0641\u0639</div>\n      </td>\n      <td>{{ doc.payment_terms_template or \"\" }}</td>\n      <td class=\"lbl\">\n        <div class=\"en\">Sales Person</div>\n        <div class=\"ar\">\u0645\u0646\u062f\u0648\u0628 \u0645\u0628\u064a\u0639\u0627\u062a</div>\n      </td>\n      <td>\n        {% for sp in doc.sales_team %}\n          {{ sp.sales_person }}{% if not loop.last %}, {% endif %}\n        {% endfor %}\n      </td>\n    </tr>\n    <tr>\n      <td class=\"lbl\">\n        <div class=\"en\">Territory</div>\n        <div class=\"ar\">\u0625\u0642\u0644\u064a\u0645</div>\n      </td>\n      <td>{{ doc.territory or \"\" }}</td>\n      <td class=\"lbl\">\n        <div class=\"en\">Source</div>\n        <div class=\"ar\">\u0627\u0644\u0645\u0635\u062f\u0631</div>\n      </td>\n      <td>{{ doc.source or \"\" }}</td>\n    </tr>\n  </table>\n\n  <!-- BILLING & SHIPPING ADDRESS -->\n  <!-- CSV: Billing Address -> \u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0630\u064a \u062a\u0631\u0633\u0644 \u0628\u0647 \u0627\u0644\u0641\u0648\u0627\u062a\u064a\u0631 | Shipping Address -> \u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0634\u062d\u0646 | Customer -> \u0627\u0644\u0639\u0645\u064a\u0644 -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"width:50%; vertical-align:top; padding:6px; border-right:2px solid #000;\">\n        <div><b>Billing Address / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0630\u064a \u062a\u0631\u0633\u0644 \u0628\u0647 \u0627\u0644\u0641\u0648\u0627\u062a\u064a\u0631</span></b></div>\n        <div>{{ doc.customer_name }}</div>\n        {{ doc.address_display or \"\" }}\n        {% set ba = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None %}\n        {% if ba %}\n          <div>Emirate / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u0625\u0645\u0627\u0631\u0629</span> : {{ ba.state or \"\" }}</div>\n          <div>Country / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u062f\u0648\u0644\u0629</span> : {{ ba.country or \"\" }}</div>\n          <div>TRN / <span class=\"ar\" style=\"font-size:10px;\">\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0636\u0631\u064a\u0628\u064a</span> : {{ ba.gstin or \"\" }}</div>\n        {% endif %}\n      </td>\n      <td style=\"width:50%; vertical-align:top; padding:6px;\">\n        {% if doc.shipping_address_name %}\n          <div><b>Shipping Address / <span class=\"ar\" style=\"font-size:10px;\">\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0634\u062d\u0646</span></b></div>\n          <div>{{ doc.shipping_address_name }}</div>\n          {{ doc.shipping_address or \"\" }}\n        {% endif %}\n      </td>\n    </tr>\n  </table>\n\n  <!-- ITEMS TABLE -->\n  <!-- CSV:\n       \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u062a\u0633\u0644\u0633\u0644\u064a -> Sr No.\n       \u0648\u0635\u0641 \u0627\u0644\u0628\u0636\u0627\u0639\u0629   -> Description of Goods\n       \u0627\u0644\u0643\u0645\u064a\u0629         -> Quantity\n       \u0648\u062d\u062f\u0629 \u0627\u0644\u0642\u064a\u0627\u0633   -> Unit of Measure (UOM)\n       \u0633\u0639\u0631 \u0627\u0644\u0633\u0644\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u062f\u0629 -> Rate\n       \u0627\u0644\u0645\u0628\u0644\u063a         -> Amount\n       \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0633\u0644\u064a\u0645  -> Delivery Date\n  -->\n  <table class=\"mb items-table\" style=\"border-bottom:none;\">\n    <thead>\n      <tr>\n        <th style=\"width:28px;\">\n          \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u062a\u0633\u0644\u0633\u0644\u064a<br><span style=\"font-size:9px;\">Sr No.</span>\n        </th>\n        <th style=\"width:90px;\">\n          \u0631\u0645\u0632 \u0627\u0644\u0635\u0646\u0641<br><span style=\"font-size:9px;\">Item Code</span>\n        </th>\n        <th>\n          \u0648\u0635\u0641 \u0627\u0644\u0628\u0636\u0627\u0639\u0629<br><span style=\"font-size:9px;\">Description of Goods</span>\n        </th>\n        <th style=\"width:55px;\">\n          \u0627\u0644\u0643\u0645\u064a\u0629<br><span style=\"font-size:9px;\">Quantity</span>\n        </th>\n        <th style=\"width:45px;\">\n          \u0648\u062d\u062f\u0629 \u0627\u0644\u0642\u064a\u0627\u0633<br><span style=\"font-size:9px;\">UOM</span>\n        </th>\n        <th style=\"width:65px;\">\n          \u0633\u0639\u0631 \u0627\u0644\u0633\u0644\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u062f\u0629<br><span style=\"font-size:9px;\">Rate (AED)</span>\n        </th>\n        <th style=\"width:75px;\">\n          \u0627\u0644\u0645\u0628\u0644\u063a<br><span style=\"font-size:9px;\">Amount (AED)</span>\n        </th>\n        <th style=\"width:75px;\">\n          \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0633\u0644\u064a\u0645<br><span style=\"font-size:9px;\">Delivery Date</span>\n        </th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for item in doc.items %}\n      <tr>\n        <td class=\"text-center\">{{ loop.index }}</td>\n        <td>{{ item.item_code }}</td>\n        <td>\n          <b>{{ item.item_name }}</b>\n          {% if item.description and item.description != item.item_name %}\n            <br><small>{{ item.description }}</small>\n          {% endif %}\n        </td>\n        <td class=\"text-center\">{{ item.qty | int }}</td>\n        <td class=\"text-center\">{{ item.uom }}</td>\n        <td class=\"text-right\">{{ \"%.2f\" | format(item.rate) }}</td>\n        <td class=\"text-right bold\">{{ \"%.2f\" | format(item.amount) }}</td>\n        <td class=\"text-center\">{{ item.delivery_date or \"\" }}</td>\n      </tr>\n      {% endfor %}\n      {% set total = doc.items | length %}\n      {% if total < 5 %}\n        {% for i in range(5 - total) %}\n        <tr style=\"height:18px;\"><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>\n        {% endfor %}\n      {% endif %}\n    </tbody>\n    <tfoot>\n      <!-- CSV: Total -> \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a \u063a\u064a\u0631 \u0634\u0627\u0645\u0644 \u0627\u0644\u0636\u0631\u064a\u0628\u0629 -->\n      <tr>\n        <td colspan=\"5\" class=\"text-right bold\">\n          \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a \u063a\u064a\u0631 \u0634\u0627\u0645\u0644 \u0627\u0644\u0636\u0631\u064a\u0628\u0629 / <span style=\"font-size:9px;\">Total (Excl. Tax)</span>\n        </td>\n        <td></td>\n        <td class=\"text-right bold\">{{ \"%.2f\" | format(doc.total) }}</td>\n        <td></td>\n      </tr>\n    </tfoot>\n  </table>\n\n  <!-- TAXES & TOTALS -->\n  <!-- CSV:\n       Taxes and Charges    -> \u0627\u0644\u0636\u0631\u0627\u0626\u0628 \u0648\u0627\u0644\u0631\u0633\u0648\u0645\n       Taxable Value        -> \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u062e\u0627\u0636\u0639\u0629 \u0644\u0644\u0636\u0631\u064a\u0628\u0629\n       Value Added Tax      -> \u0636\u0631\u064a\u0628\u0629 \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0636\u0627\u0641\u0629\n       Discount             -> \u0627\u0644\u062e\u0635\u0645\n       Rounded Off          -> \u0627\u0644\u062a\u0642\u0631\u064a\u0628\n       Grand Total          -> \u0627\u0644\u0645\u062c\u0645\u0648\u0639 \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a\n       Amount in words      -> \u0627\u0644\u0645\u0628\u0644\u063a \u0628\u0627\u0644\u0643\u0644\u0645\u0627\u062a\n  -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"width:55%; vertical-align:top;\">\n        <b>\u0627\u0644\u0645\u0628\u0644\u063a \u0628\u0627\u0644\u0643\u0644\u0645\u0627\u062a</b> / Amount Chargeable (in words)<br>\n        {{ doc.in_words or \"\" }}\n      </td>\n      <td style=\"width:45%; padding:0;\">\n        <table style=\"width:100%; border-collapse:collapse;\">\n          <tr>\n            <td style=\"border:1px solid #000; padding:3px 8px;\">\n              \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u062e\u0627\u0636\u0639\u0629 \u0644\u0644\u0636\u0631\u064a\u0628\u0629<br><span style=\"font-size:9px;\">Taxable Value</span>\n            </td>\n            <td style=\"border:1px solid #000; padding:3px 8px; text-align:right; vertical-align:middle;\">\n              {{ \"%.2f\" | format(doc.total) }}\n            </td>\n          </tr>\n          {% for tax in doc.taxes %}\n          <tr>\n            <td style=\"border:1px solid #000; padding:3px 8px;\">\n              {% if \"VAT\" in tax.description or \"Tax\" in tax.description %}\n                \u0636\u0631\u064a\u0628\u0629 \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0636\u0627\u0641\u0629 {{ tax.rate }}%<br><span style=\"font-size:9px;\">{{ tax.description }}</span>\n              {% else %}\n                {{ tax.description }}\n              {% endif %}\n            </td>\n            <td style=\"border:1px solid #000; padding:3px 8px; text-align:right; vertical-align:middle;\">\n              {{ \"%.2f\" | format(tax.tax_amount) }}\n            </td>\n          </tr>\n          {% endfor %}\n          {% if doc.discount_amount %}\n          <tr>\n            <td style=\"border:1px solid #000; padding:3px 8px;\">\n              \u0627\u0644\u062e\u0635\u0645<br><span style=\"font-size:9px;\">Discount</span>\n            </td>\n            <td style=\"border:1px solid #000; padding:3px 8px; text-align:right; vertical-align:middle;\">\n              (-{{ \"%.2f\" | format(doc.discount_amount) }})\n            </td>\n          </tr>\n          {% endif %}\n          {% if doc.rounding_adjustment %}\n          <tr>\n            <td style=\"border:1px solid #000; padding:3px 8px;\">\n              \u0627\u0644\u062a\u0642\u0631\u064a\u0628<br><span style=\"font-size:9px;\">Rounded Off</span>\n            </td>\n            <td style=\"border:1px solid #000; padding:3px 8px; text-align:right; vertical-align:middle;\">\n              {{ \"%.2f\" | format(doc.rounding_adjustment) }}\n            </td>\n          </tr>\n          {% endif %}\n          <tr class=\"grand-total\">\n            <td style=\"border:1px solid #000; padding:3px 8px;\">\n              <b>\u0627\u0644\u0645\u062c\u0645\u0648\u0639 \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a</b><br><span style=\"font-size:9px;\">Grand Total</span>\n            </td>\n            <td style=\"border:1px solid #000; padding:3px 8px; text-align:right; vertical-align:middle;\">\n              <b>\n                {% if doc.disable_rounded_total %}\n                  {{ \"%.2f\" | format(doc.grand_total) }}\n                {% else %}\n                  {{ \"%.2f\" | format(doc.rounded_total or doc.grand_total) }}\n                {% endif %}\n              </b>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n\n  <!-- TERMS & CONDITIONS -->\n  <!-- CSV: Terms and Conditions -> \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 -->\n  {% if doc.terms %}\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td>\n        <b>\u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645</b> / Terms and Conditions<br>\n        <span style=\"font-size:10px;\">{{ doc.terms }}</span>\n      </td>\n    </tr>\n  </table>\n  {% endif %}\n\n  <!-- SIGNATURE -->\n  <!-- CSV: for -> \u0644\u0635\u0627\u0644\u062d | Authorized Signatory -> \u0627\u0644\u0645\u062e\u0648\u0644 \u0628\u0627\u0644\u062a\u0648\u0642\u064a\u0639 -->\n  <table class=\"mb\" style=\"border-bottom:none;\">\n    <tr>\n      <td style=\"width:50%; vertical-align:top; padding:6px;\">\n        <b>Customer Acceptance / <span class=\"ar\" style=\"font-size:10px;\">\u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u0639\u0645\u064a\u0644</span></b><br><br><br><br>\n        <div style=\"border-top:1px solid #000; margin-top:10px; padding-top:4px; text-align:center; font-size:10px;\">\n          \u062a\u0648\u0642\u064a\u0639 \u0627\u0644\u0639\u0645\u064a\u0644 / Customer Signature\n        </div>\n      </td>\n      <td style=\"width:50%; vertical-align:bottom; padding:6px;\">\n        <div style=\"text-align:center; padding-top:30px; font-size:10px;\">\n          \u0644\u0635\u0627\u0644\u062d / for <b>{{ doc.company }}</b><br><br><br>\n          \u0627\u0644\u0645\u062e\u0648\u0644 \u0628\u0627\u0644\u062a\u0648\u0642\u064a\u0639 / Authorised Signatory\n        </div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- BOTTOM NOTE -->\n  <!-- CSV: This is a Computer Generated Invoice -> \u0647\u0630\u0647 \u0641\u0627\u062a\u0648\u0631\u0629 \u0635\u0627\u062f\u0631\u0629 \u0628\u0648\u0627\u0633\u0637\u0629 \u0627\u0644\u062d\u0627\u0633\u0628 \u0627\u0644\u0622\u0644\u064a -->\n  <div class=\"bottom-note\">\n    \u0647\u0630\u0647 \u0648\u062b\u064a\u0642\u0629 \u0635\u0627\u062f\u0631\u0629 \u0628\u0648\u0627\u0633\u0637\u0629 \u0627\u0644\u062d\u0627\u0633\u0628 \u0627\u0644\u0622\u0644\u064a / This is a Computer Generated Document\n  </div>\n\n</div>\n</body>\n</html>",
